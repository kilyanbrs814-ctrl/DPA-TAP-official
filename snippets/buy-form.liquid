{% comment %}
  Formulaire d'achat connecté aux variantes — utilisé sur l'accueil et la page produit.
  « Pack 2 plaques » : ajoute 2 lignes au panier, avec couleur, nom d'établissement et lien
  Google propres à chaque plaque. Le prix pack (2 × prix unitaire − 9,90 €) et la livraison
  offerte doivent être portés au checkout par deux réductions automatiques Shopify combinables
  (minimum 2 articles) : « 9,90 € de remise » + « livraison gratuite ». Le montant 990 ci-dessous
  doit rester aligné avec PACK_DISCOUNT dans theme.js et avec la réduction automatique.
{% endcomment %}
{% assign current = product.selected_or_first_available_variant | default: product.variants.first %}
{% assign pack_full_price = current.price | times: 2 %}
{% assign pack_price = pack_full_price | minus: 990 %}
{% assign v_black = blank %}
{% assign v_blue = blank %}
{% for variant in product.variants %}
  {% assign lower_title = variant.title | downcase %}
  {% if lower_title contains 'bleu' or lower_title contains 'blue' %}
    {% if v_blue == blank %}{% assign v_blue = variant %}{% endif %}
  {% elsif v_black == blank %}
    {% assign v_black = variant %}
  {% endif %}
{% endfor %}
{% if v_black == blank %}{% assign v_black = current %}{% endif %}
{% if v_blue == blank %}{% assign v_blue = current %}{% endif %}
<script type="application/json" data-variants>{{ product.variants | json }}</script>
{% form 'product', product, data-product-form: '', novalidate: 'novalidate' %}
  <input type="hidden" name="id" value="{{ current.id }}" data-variant-id>

  <fieldset class="vcards" data-pack-single style="border:0;padding:0;margin:0 0 30px">
    <legend class="eyebrow" style="margin-bottom:16px;padding:0">Choisissez votre modèle</legend>
    {% for variant in product.variants %}
      {% assign fallback_asset = 'plaque-noire.jpg' %}
      {% assign lower_title = variant.title | downcase %}
      {% if lower_title contains 'bleu' or lower_title contains 'blue' %}{% assign fallback_asset = 'plaque-bleue.jpg' %}{% endif %}
      {% assign fallback_url = fallback_asset | asset_url %}
      <label class="vcard{% if variant.id == current.id %} is-active{% endif %}{% unless variant.available %} is-disabled{% endunless %}" data-image="{{ fallback_url }}">
        <input type="radio" name="variant-choice" value="{{ variant.id }}" data-variant-radio {% if variant.id == current.id %}checked{% endif %}{% unless variant.available %} data-unavailable disabled{% endunless %}>
        {% if variant.featured_image %}
          {{ variant.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 800', sizes: '(max-width: 560px) 90vw, 320px', alt: variant.title }}
        {% else %}
          {% assign fallback_webp_base = fallback_asset | replace: '.jpg', '' %}
          <picture style="display:contents">
            <source type="image/webp" srcset="{{ fallback_webp_base | append: '-400.webp' | asset_url }} 400w, {{ fallback_webp_base | append: '-800.webp' | asset_url }} 800w" sizes="(max-width: 560px) 90vw, 320px">
            <img src="{{ fallback_url }}" width="1254" height="1254" loading="lazy" alt="{{ variant.title | escape }}">
          </picture>
        {% endif %}
        <span class="vcard-meta">
          <span class="vcard-name">{{ variant.title }}</span>
          {% unless variant.available %}<span class="vcard-status">Épuisé</span>{% endunless %}
        </span>
        <span class="vcard-check" aria-hidden="true">✓</span>
      </label>
    {% endfor %}
  </fieldset>

  <fieldset class="packs" style="border:0;padding:0;margin:0 0 30px">
    <legend class="eyebrow" style="margin-bottom:16px;padding:0">Choisissez votre offre</legend>
    <label class="pack is-active">
      <input type="radio" name="pack-choice" value="1" data-pack-radio checked>
      <span class="pack-dot" aria-hidden="true"></span>
      <span class="pack-info">
        <span class="pack-name">1 plaque</span>
      </span>
      <span class="pack-price" data-pack-price="1">{{ current.price | money }}</span>
    </label>
    <label class="pack">
      <input type="radio" name="pack-choice" value="2" data-pack-radio>
      <span class="pack-dot" aria-hidden="true"></span>
      <span class="pack-info">
        <span class="pack-name"><span class="pack-mobile-prefix">Pack </span>2 plaques</span>
        <span class="pack-badge">Économisez {{ 990 | money }}</span>
        <span class="pack-badge">Livraison offerte</span>
        <span class="pack-note" style="display:block;font-size:.78rem;opacity:.65;margin-top:2px">Au lieu de {{ pack_full_price | money }} séparément</span>
      </span>
      <span class="pack-price" data-pack-price="2">{{ pack_price | money }}</span>
    </label>
  </fieldset>

  {% comment %} Combinaisons du pack de 2 — images à déposer dans assets/ avec exactement ces noms. {% endcomment %}
  <fieldset class="vcards vcards--trio" data-pack-duo hidden style="border:0;padding:0;margin:0 0 30px">
    <legend class="eyebrow" style="margin-bottom:16px;padding:0">Choisissez votre combinaison</legend>
    <label class="vcard is-active{% unless v_black.available %} is-disabled{% endunless %}">
      <input type="radio" name="combo-{{ section.id }}" value="noire-noire" data-combo
             data-v1="{{ v_black.id }}" data-v2="{{ v_black.id }}"
             data-label="2 plaques noires" data-image="{{ 'pack-2-noires-1254.webp' | asset_url }}" data-image-mobile="{{ 'pack-2-noires-mobile.jpg' | asset_url }}" checked disabled{% unless v_black.available %} data-unavailable{% endunless %}>
      <picture><source media="(max-width: 560px)" srcset="{{ 'pack-2-noires-mobile.jpg' | asset_url }}"><source type="image/webp" srcset="{{ 'pack-2-noires-400.webp' | asset_url }} 400w, {{ 'pack-2-noires-800.webp' | asset_url }} 800w" sizes="(max-width: 560px) 90vw, 320px"><img src="{{ 'pack-2-noires.png' | asset_url }}" width="1254" height="1254" loading="lazy" alt="2 plaques noires"></picture>
      <span class="vcard-meta"><span class="vcard-name">2 plaques noires</span>{% unless v_black.available %}<span class="vcard-status">Indisponible</span>{% endunless %}</span>
      <span class="vcard-check" aria-hidden="true">✓</span>
    </label>
    <label class="vcard{% unless v_black.available and v_blue.available %} is-disabled{% endunless %}">
      <input type="radio" name="combo-{{ section.id }}" value="noire-bleue" data-combo
             data-v1="{{ v_black.id }}" data-v2="{{ v_blue.id }}"
             data-label="1 noire + 1 bleue" data-image="{{ 'pack-noire-bleue-1254.webp' | asset_url }}" data-image-mobile="{{ 'pack-noire-bleue-mobile.jpg' | asset_url }}" disabled{% unless v_black.available and v_blue.available %} data-unavailable{% endunless %}>
      <picture><source media="(max-width: 560px)" srcset="{{ 'pack-noire-bleue-mobile.jpg' | asset_url }}"><source type="image/webp" srcset="{{ 'pack-noire-bleue-400.webp' | asset_url }} 400w, {{ 'pack-noire-bleue-800.webp' | asset_url }} 800w" sizes="(max-width: 560px) 90vw, 320px"><img src="{{ 'pack-noire-bleue.png' | asset_url }}" width="1254" height="1254" loading="lazy" alt="1 plaque noire + 1 plaque bleue"></picture>
      <span class="vcard-meta"><span class="vcard-name">1 noire + 1 bleue</span>{% unless v_black.available and v_blue.available %}<span class="vcard-status">Indisponible</span>{% endunless %}</span>
      <span class="vcard-check" aria-hidden="true">✓</span>
    </label>
    <label class="vcard{% unless v_blue.available %} is-disabled{% endunless %}">
      <input type="radio" name="combo-{{ section.id }}" value="bleue-bleue" data-combo
             data-v1="{{ v_blue.id }}" data-v2="{{ v_blue.id }}"
             data-label="2 plaques bleues" data-image="{{ 'pack-2-bleues-1254.webp' | asset_url }}" data-image-mobile="{{ 'pack-2-bleues-mobile.jpg' | asset_url }}" disabled{% unless v_blue.available %} data-unavailable{% endunless %}>
      <picture><source media="(max-width: 560px)" srcset="{{ 'pack-2-bleues-mobile.jpg' | asset_url }}"><source type="image/webp" srcset="{{ 'pack-2-bleues-400.webp' | asset_url }} 400w, {{ 'pack-2-bleues-800.webp' | asset_url }} 800w" sizes="(max-width: 560px) 90vw, 320px"><img src="{{ 'pack-2-bleues.png' | asset_url }}" width="1254" height="1254" loading="lazy" alt="2 plaques bleues"></picture>
      <span class="vcard-meta"><span class="vcard-name">2 plaques bleues</span>{% unless v_blue.available %}<span class="vcard-status">Indisponible</span>{% endunless %}</span>
      <span class="vcard-check" aria-hidden="true">✓</span>
    </label>
  </fieldset>

  <p class="buy-avail{% unless current.available %} is-out{% endunless %}" data-availability role="status" aria-live="polite"
     data-in-stock="En stock — expédiée sous 24 h" data-out-stock="Épuisé — bientôt de retour">
    {% if current.available %}En stock — expédiée sous 24 h{% else %}Épuisé — bientôt de retour{% endif %}
  </p>

  <div data-pack-single>
    <div class="buy-field">
      <label for="prop-name-{{ section.id }}">Nom de l’établissement</label>
      <input id="prop-name-{{ section.id }}" type="text" name="properties[Nom de l’établissement]" required autocomplete="organization" placeholder="Ex. Café des Halles">
    </div>
    <div class="buy-field">
      <label for="prop-link-{{ section.id }}">Lien Google</label>
      <input id="prop-link-{{ section.id }}" type="url" name="properties[Lien Google]" placeholder="https://g.page/r/…" inputmode="url">
      <p class="hint">Le lien de votre fiche Google. Pas encore sous la main ? Nous vous le retrouvons.</p>
    </div>
  </div>

  <div class="pack-plaques" data-pack-duo hidden>
    {% for i in (1..2) %}
      <div class="plaque-panel" role="group" aria-labelledby="plaque-title-{{ i }}-{{ section.id }}">
        <p class="plaque-title" id="plaque-title-{{ i }}-{{ section.id }}">Plaque {{ i }}</p>
        <div class="buy-field">
          <label for="prop-name-{{ i }}-{{ section.id }}">Nom de l’établissement</label>
          <input id="prop-name-{{ i }}-{{ section.id }}" type="text" data-plaque-name="{{ i }}" required autocomplete="organization" placeholder="Ex. Café des Halles" disabled>
        </div>
        <div class="buy-field">
          <label for="prop-link-{{ i }}-{{ section.id }}">Lien Google</label>
          <input id="prop-link-{{ i }}-{{ section.id }}" type="url" data-plaque-link="{{ i }}" placeholder="https://g.page/r/…" inputmode="url" disabled>
          {% if i == 1 %}<p class="hint">Le lien de votre fiche Google. Pas encore sous la main ? Nous vous le retrouvons.</p>{% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="buy-field">
    <label for="prop-note-{{ section.id }}">Remarque <span style="text-transform:none;letter-spacing:0">(facultatif)</span></label>
    <textarea id="prop-note-{{ section.id }}" name="properties[Remarque]" placeholder="Une précision pour la programmation ?"></textarea>
  </div>

  <button type="submit" name="add" class="btn btn--blue buy-submit" data-add-btn
          data-label-add="Ajouter au panier" data-label-sold-out="Épuisé"
          aria-describedby="buy-error-{{ section.id }}"
          {% unless current.available %}disabled{% endunless %}>
    <span class="spinner" aria-hidden="true"></span>
    <span class="check" aria-hidden="true">✓</span>
    <span class="label">{% if current.available %}Ajouter au panier{% else %}Épuisé{% endif %}</span>
  </button>
  <div data-pack-single>{{ form | payment_button }}</div>
  <p class="buy-error" id="buy-error-{{ section.id }}" data-form-error role="alert" tabindex="-1" hidden></p>
  <div class="buy-success" data-form-success role="status" aria-live="polite" hidden>
    <span>Ajouté au panier ✓</span>
    <span><a href="{{ routes.cart_url }}">Voir le panier</a> · <a href="{{ routes.root_url }}checkout">Payer</a></span>
  </div>
{% endform %}

<ul class="reassure">
  <li>NFC programmé avant expédition</li>
  <li>Adhésif 3M au verso</li>
  <li>Format 10 × 10 cm</li>
  <li>Aucun abonnement</li>
  <li>Prête à l’emploi</li>
</ul>
