{%- comment -%}
  Icônes SVG inline du bandeau défilant DPA TAP.
  Style unifié : viewBox 24x24, fill none, stroke currentColor, épaisseur 1.6,
  extrémités et jonctions arrondies. Décoratives => aria-hidden.
  Usage : {% render 'dpa-marquee-icon', name: 'truck' %}
{%- endcomment -%}
{%- capture shapes -%}
{%- case name -%}
  {%- when 'truck' -%}
    <path d="M2.75 6.25h10.5v8.5H2.75z"/><path d="M13.25 9.25h3.6l3.4 3v2.5h-7z"/><path d="M4.6 14.75h-1.85M8.4 17.6h5.9"/><circle cx="6.5" cy="17.6" r="1.9"/><circle cx="16.2" cy="17.6" r="1.9"/>
  {%- when 'package' -%}
    <path d="M12 2.9l8.4 4.4v9.4L12 21.1l-8.4-4.4V7.3z"/><path d="M3.6 7.3l8.4 4.4 8.4-4.4"/><path d="M12 11.7v9.4"/><path d="M7.8 5.1l8.4 4.4"/>
  {%- when 'shield' -%}
    <path d="M12 2.9l7.3 2.9v5.6c0 4.3-3 7.8-7.3 9.7-4.3-1.9-7.3-5.4-7.3-9.7V5.8z"/><path d="M9.1 11.9l2 2 3.8-3.9"/>
  {%- when 'infinity' -%}
    <path d="M9.2 12c0 1.9-1.5 3.4-3.3 3.4S2.6 13.9 2.6 12s1.5-3.4 3.3-3.4c2.7 0 4 3.4 6.1 3.4s3.4-3.4 6.1-3.4c1.8 0 3.3 1.5 3.3 3.4s-1.5 3.4-3.3 3.4-3.4-3.4-6.1-3.4"/>
  {%- when 'badge' -%}
    <circle cx="12" cy="9.3" r="6.4"/><path d="M9.4 11.2l1.7 1.7 3.4-3.4"/><path d="M8.2 14.6l-1.3 6.3 5.1-2.6 5.1 2.6-1.3-6.3"/>
  {%- when 'no-card' -%}
    <rect x="2.7" y="5.4" width="18.6" height="13.2" rx="2.2"/><path d="M2.7 9.7h18.6"/><path d="M4.3 20.5L19.7 3.5"/>
  {%- when 'calendar-off' -%}
    <rect x="3.2" y="5" width="17.6" height="16" rx="2.2"/><path d="M3.2 9.8h17.6M8.2 3v4M15.8 3v4"/><path d="M4.3 21.2L19.7 3.4"/>
  {%- when 'wallet' -%}
    <path d="M3 7.2A2.2 2.2 0 0 1 5.2 5h12.3a2.2 2.2 0 0 1 2.2 2.2v1.1"/><rect x="3" y="7.2" width="18" height="11.8" rx="2.2"/><path d="M16.3 13.1h4.7"/>
  {%- when 'stopwatch' -%}
    <circle cx="12" cy="13.6" r="7.5"/><path d="M12 9.9v3.7l2.4 1.4"/><path d="M9.5 2.6h5M12 2.6v3.5"/><path d="M18.8 6.1l1.6-1.6"/>
  {%- when 'bolt' -%}
    <path d="M13.3 2.6L5.2 13.4h5.9l-1.4 8L18.8 10.6h-5.9z"/>
  {%- when 'phone' -%}
    <rect x="6.6" y="2.4" width="10.8" height="19.2" rx="2.4"/><path d="M10.4 5.3h3.2"/><path d="M12 18.3h.01"/>
  {%- when 'check' -%}
    <circle cx="12" cy="12" r="9.1"/><path d="M8.1 12.2l2.6 2.6 5.2-5.4"/>
  {%- when 'star' -%}
    <path d="M12 3.1l2.8 5.7 6.3.9-4.5 4.4 1 6.2-5.6-2.9-5.6 2.9 1-6.2-4.5-4.4 6.3-.9z"/>
  {%- when 'lock' -%}
    <rect x="4.2" y="10.2" width="15.6" height="10.6" rx="2.2"/><path d="M8 10.2V7.6a4 4 0 0 1 8 0v2.6"/><path d="M12 14.6v2"/>
  {%- when 'globe' -%}
    <circle cx="12" cy="12" r="9.1"/><path d="M2.9 12h18.2"/><path d="M12 2.9c2.3 2.5 3.6 5.7 3.6 9.1s-1.3 6.6-3.6 9.1c-2.3-2.5-3.6-5.7-3.6-9.1S9.7 5.4 12 2.9z"/>
{%- endcase -%}
{%- endcapture -%}

{%- if shapes != blank -%}
  <svg class="dpa-mq__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">{{ shapes }}</svg>
{%- endif -%}
