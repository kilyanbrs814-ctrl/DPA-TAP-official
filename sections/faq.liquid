<section class="faq" id="faq">
  <div class="container">
    <div class="bene-head">
      <h2 class="h-xl reveal">{{ section.settings.title | default: 'Les questions qu’on nous pose.' }}</h2>
      <p class="eyebrow reveal">{{ section.settings.eyebrow | default: 'FAQ' }}</p>
    </div>
    <div class="faq-list">
      {% for block in section.blocks %}
        <details class="faq-item" {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}<span class="plus" aria-hidden="true">+</span></summary>
          <div class="faq-body">{{ block.settings.answer }}</div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "FAQ" },
    { "type": "text", "id": "title", "label": "Titre", "default": "Les questions qu’on nous pose." }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Comment la plaque est-elle programmée ?" },
        { "type": "richtext", "id": "answer", "label": "Réponse", "default": "<p>Réponse…</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "Comment la plaque est-elle programmée ?", "answer": "<p>Vous nous indiquez le nom de votre établissement et votre lien Google au moment de la commande. Nous programmons la puce NFC avant l’expédition : la plaque arrive prête à l’emploi.</p>" } },
        { "type": "qa", "settings": { "question": "Le client doit-il installer une application ?", "answer": "<p>Non. Le NFC est natif sur tous les smartphones récents, iPhone comme Android. Le client approche son téléphone, la page d’avis s’ouvre, il note. C’est tout.</p>" } },
        { "type": "qa", "settings": { "question": "Y a-t-il un abonnement ?", "answer": "<p>Aucun. Vous achetez la plaque une seule fois, elle vous appartient et fonctionne sans limite de durée ni de scans.</p>" } },
        { "type": "qa", "settings": { "question": "Et si je change de lien Google ?", "answer": "<p>Écrivez-nous : nous vous expliquons comment reprogrammer la puce gratuitement, ou nous le faisons pour vous.</p>" } },
        { "type": "qa", "settings": { "question": "Sur quelles surfaces tient l’adhésif ?", "answer": "<p>L’adhésif 3M au verso tient sur bois, verre, métal, carrelage et stratifié. Format 10 × 10 cm, résistant aux nettoyages quotidiens.</p>" } }
      ]
    }
  ]
}
{% endschema %}
