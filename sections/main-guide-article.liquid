{% liquid
  assign featured_product = section.settings.product
  assign article_kind = 'plain'
  if article.handle contains 'comment-ca-marche'
    assign article_kind = 'nfc'
  elsif article.handle contains 'nfc-ou-qr-code'
    assign article_kind = 'compare'
  elsif article.handle contains 'comment-obtenir-lien'
    assign article_kind = 'link'
  endif

  assign content_marker = '<!--guide-body-->'
  assign content_parts = article.content | split: content_marker
  assign content_part_count = content_parts | size
  assign main_content = article.content
  assign quick_summary = blank
  if content_part_count > 1
    assign quick_summary = content_parts | first
    assign main_content = content_parts | last
  endif

  assign article_date = article.updated_at | default: article.published_at
  assign article_intro = article.excerpt | default: section.settings.intro_fallback
%}

<section class="guide-article guide-article--{{ article_kind }}" data-guide-article>
  <div class="container">
    {% render 'seo-breadcrumbs', current_title: article.title, parent_title: blog.title, parent_url: blog.url %}

    <article class="guide-article__layout">
      <header class="guide-hero">
        <div class="guide-hero__copy">
          <div class="guide-badge">
            <span class="g-dots" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
            {{ section.settings.badge }}
          </div>
          <h1>{{ article.title }}</h1>
          {% if article_intro != blank %}<div class="guide-hero__dek">{{ article_intro }}</div>{% endif %}
          <div class="guide-hero__meta">
            <span><strong data-reading-time>{{ section.settings.reading_time_fallback }}</strong> {{ section.settings.reading_time_label }}</span>
            {% if article_date != blank %}
              <span>{{ section.settings.updated_label }} <time datetime="{{ article_date | date: '%Y-%m-%d' }}">{{ article_date | date: '%d/%m/%Y' }}</time></span>
            {% endif %}
          </div>
        </div>

        <figure class="guide-hero__visual guide-hero__visual--{{ article_kind }}">
          {% if article.image %}
            {{ article.image | image_url: width: 1600 | image_tag: class: 'guide-hero__image', loading: 'eager', fetchpriority: 'high', widths: '360, 540, 760, 1000, 1280, 1600', sizes: '(max-width: 799px) calc(100vw - 32px), 44vw', alt: article.image.alt | default: article.title }}
          {% elsif article_kind == 'nfc' %}
            <div class="signal-scene" role="img" aria-label="{{ 'seo.guide_nfc.hero_alt' | t }}">
              {% if featured_product.featured_image %}
                {{ featured_product.featured_image | image_url: width: 800 | image_tag: class: 'signal-scene__plaque', loading: 'eager', fetchpriority: 'high', widths: '320, 480, 640, 800', sizes: '(max-width: 799px) 48vw, 250px', alt: featured_product.featured_image.alt | default: featured_product.title }}
              {% endif %}
              <div class="signal-scene__waves" aria-hidden="true"><span></span><span></span><span></span></div>
              <div class="signal-scene__phone" aria-hidden="true">
                <span class="signal-scene__notch"></span>
                <span class="signal-scene__notice"><b>NFC</b><small>{{ 'seo.guide_nfc.detected' | t }}</small></span>
              </div>
            </div>
          {% elsif article_kind == 'compare' %}
            <div class="compare-scene" role="img" aria-label="{{ 'seo.guide_compare.hero_alt' | t }}">
              <div class="compare-scene__card compare-scene__card--nfc">
                <span class="compare-scene__label">NFC</span>
                <svg viewBox="0 0 64 64" aria-hidden="true"><path d="M18 42c8-8 8-20 0-28M28 48c12-12 12-30 0-42M38 53c16-16 16-40 0-56" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/></svg>
                <small>{{ 'seo.guide_compare.approach' | t }}</small>
              </div>
              <div class="compare-scene__versus" aria-hidden="true">/</div>
              <div class="compare-scene__card compare-scene__card--qr">
                <span class="compare-scene__label">QR</span>
                <svg viewBox="0 0 64 64" aria-hidden="true"><path d="M8 8h18v18H8zM38 8h18v18H38zM8 38h18v18H8zM40 38h7v7h-7zM50 38h6v18H44v-6h6zM32 31h8v8h-8z" fill="currentColor"/></svg>
                <small>{{ 'seo.guide_compare.frame' | t }}</small>
              </div>
            </div>
          {% elsif article_kind == 'link' %}
            <div class="link-scene" role="img" aria-label="{{ 'seo.guide_link.hero_alt' | t }}">
              <div class="link-scene__browser" aria-hidden="true">
                <div class="link-scene__browserbar"><span></span><span></span><span></span></div>
                <div class="link-scene__profile">
                  <span class="link-scene__avatar">DPA</span>
                  <span><b>{{ 'seo.guide_link.profile' | t }}</b><small>{{ 'seo.guide_link.business' | t }}</small></span>
                </div>
                <div class="link-scene__action">{{ 'seo.guide_link.receive' | t }}</div>
              </div>
              <div class="link-scene__url"><span>https://g.page/r/…/review</span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9.5 14.5l5-5m-7.8 8.8l-1 1a3.5 3.5 0 0 1-5-5l3-3a3.5 3.5 0 0 1 5 0m6.6-5.6l1-1a3.5 3.5 0 0 1 5 5l-3 3a3.5 3.5 0 0 1-5 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></div>
            </div>
          {% endif %}
        </figure>
      </header>

      {% if quick_summary != blank %}
        <div class="guide-summary">{{ quick_summary }}</div>
      {% endif %}

      {% case article_kind %}
        {% when 'nfc' %}
          <section class="guide-feature guide-feature--nfc" aria-labelledby="guide-nfc-steps">
            <div class="guide-section-heading">
              <p class="eyebrow">{{ 'seo.guide_nfc.eyebrow' | t }}</p>
              <h2 id="guide-nfc-steps">{{ 'seo.guide_nfc.steps_heading' | t }}</h2>
            </div>
            <ol class="signal-steps">
              <li><span class="signal-steps__number">01</span><svg viewBox="0 0 24 24" aria-hidden="true"><rect x="7" y="2" width="10" height="20" rx="2" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M10 18h4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg><h3>{{ 'seo.guide_nfc.step_1_title' | t }}</h3><p>{{ 'seo.guide_nfc.step_1_text' | t }}</p></li>
              <li><span class="signal-steps__number">02</span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 16c4-4 4-8 0-12M10 19c6-6 6-12 0-18M15 21c8-8 8-16 0-24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg><h3>{{ 'seo.guide_nfc.step_2_title' | t }}</h3><p>{{ 'seo.guide_nfc.step_2_text' | t }}</p></li>
              <li><span class="signal-steps__number">03</span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16v14H4zM4 9h16" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M8 14h8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg><h3>{{ 'seo.guide_nfc.step_3_title' | t }}</h3><p>{{ 'seo.guide_nfc.step_3_text' | t }}</p></li>
            </ol>
            <div class="compatibility-row">
              <div><span>iPhone</span><p>{{ 'seo.guide_nfc.iphone' | t }}</p></div>
              <div><span>Android</span><p>{{ 'seo.guide_nfc.android' | t }}</p></div>
              <aside><strong>{{ 'seo.guide_nfc.limit_label' | t }}</strong><p>{{ 'seo.guide_nfc.limit_text' | t }}</p></aside>
            </div>
          </section>
        {% when 'compare' %}
          <section class="guide-feature guide-feature--compare" aria-labelledby="guide-compare-heading">
            <div class="guide-section-heading">
              <p class="eyebrow">{{ 'seo.guide_compare.eyebrow' | t }}</p>
              <h2 id="guide-compare-heading">{{ 'seo.guide_compare.heading' | t }}</h2>
            </div>
            <div class="technology-cards">
              <article><span class="technology-cards__tag">NFC</span><h3>{{ 'seo.guide_compare.nfc_title' | t }}</h3><p>{{ 'seo.guide_compare.nfc_text' | t }}</p><ul><li>{{ 'seo.guide_compare.nfc_point_1' | t }}</li><li>{{ 'seo.guide_compare.nfc_point_2' | t }}</li></ul></article>
              <article><span class="technology-cards__tag">QR code</span><h3>{{ 'seo.guide_compare.qr_title' | t }}</h3><p>{{ 'seo.guide_compare.qr_text' | t }}</p><ul><li>{{ 'seo.guide_compare.qr_point_1' | t }}</li><li>{{ 'seo.guide_compare.qr_point_2' | t }}</li></ul></article>
            </div>
            <aside class="guide-callout"><span>{{ 'seo.guide_compare.choice_label' | t }}</span><p>{{ 'seo.guide_compare.choice_text' | t }}</p></aside>
          </section>
        {% when 'link' %}
          <section class="guide-feature guide-feature--link" aria-labelledby="guide-link-heading">
            <div class="guide-section-heading">
              <p class="eyebrow">{{ 'seo.guide_link.eyebrow' | t }}</p>
              <h2 id="guide-link-heading">{{ 'seo.guide_link.heading' | t }}</h2>
            </div>
            <ol class="link-path">
              <li><span>01</span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16v14H4zM4 9h16" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="7" cy="7" r=".8" fill="currentColor"/></svg><h3>{{ 'seo.guide_link.path_1_title' | t }}</h3><p>{{ 'seo.guide_link.path_1_text' | t }}</p></li>
              <li><span>02</span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a9 9 0 1 0 9 9M12 3v9h9" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg><h3>{{ 'seo.guide_link.path_2_title' | t }}</h3><p>{{ 'seo.guide_link.path_2_text' | t }}</p></li>
              <li><span>03</span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9.5 14.5l5-5m-7.8 8.8l-1 1a3.5 3.5 0 0 1-5-5l3-3a3.5 3.5 0 0 1 5 0m6.6-5.6l1-1a3.5 3.5 0 0 1 5 5l-3 3a3.5 3.5 0 0 1-5 0" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg><h3>{{ 'seo.guide_link.path_3_title' | t }}</h3><p>{{ 'seo.guide_link.path_3_text' | t }}</p></li>
            </ol>
            <div class="platform-cards">
              <article><span>{{ 'seo.guide_link.computer' | t }}</span><p>{{ 'seo.guide_link.computer_text' | t }}</p></article>
              <article><span>{{ 'seo.guide_link.phone' | t }}</span><p>{{ 'seo.guide_link.phone_text' | t }}</p></article>
            </div>
            <aside class="guide-callout"><span>{{ 'seo.guide_link.verify_label' | t }}</span><p>{{ 'seo.guide_link.verify_text' | t }}</p></aside>
          </section>
      {% endcase %}

      <div class="guide-reading">
        <details class="guide-toc" data-guide-toc open>
          <summary>{{ section.settings.toc_heading }}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m7 10 5 5 5-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></summary>
          <nav aria-label="{{ section.settings.toc_aria_label }}"><ol data-toc-list></ol></nav>
        </details>

        <div class="guide-article__content" data-guide-content>
          {{ main_content }}
        </div>
      </div>

      {% if featured_product != blank %}
        <aside class="guide-product" aria-label="{{ 'seo.product_link' | t }}">
          <div class="guide-product__media">
            {% if featured_product.featured_image %}
              {{ featured_product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '320, 480, 640, 900', sizes: '(max-width: 759px) calc(100vw - 64px), 360px', alt: featured_product.featured_image.alt | default: featured_product.title }}
            {% endif %}
          </div>
          <div class="guide-product__copy">
            <p class="eyebrow">{{ section.settings.product_eyebrow }}</p>
            <h2>{{ featured_product.title }}</h2>
            <p class="guide-product__price">{{ section.settings.price_prefix }} {{ featured_product.price_min | money }}</p>
            <ul><li>{{ section.settings.product_benefit_1 }}</li><li>{{ section.settings.product_benefit_2 }}</li><li>{{ section.settings.product_benefit_3 }}</li></ul>
            <a class="btn btn--blue" href="{{ featured_product.url }}">{{ section.settings.product_button }}</a>
          </div>
        </aside>
      {% endif %}

      <aside class="guide-related" aria-labelledby="guide-related-heading">
        <div class="guide-section-heading">
          <p class="eyebrow">{{ section.settings.related_eyebrow }}</p>
          <h2 id="guide-related-heading">{{ section.settings.related_heading }}</h2>
        </div>
        <div class="guide-related__grid">
          {% for block in section.blocks %}
            {% liquid
              assign related_article = block.settings.article
              assign related_url = block.settings.fallback_url
              assign related_title = block.settings.fallback_title
              assign related_excerpt = block.settings.fallback_excerpt
              assign related_image = block.settings.image
              if related_article != blank
                assign related_url = related_article.url
                assign related_title = related_article.title
                assign related_excerpt = related_article.excerpt | strip_html | default: related_excerpt
                assign related_image = related_article.image | default: related_image
              endif
            %}
            {% if related_url != blank and related_url != article.url %}
              <article class="guide-related__card" {{ block.shopify_attributes }}>
                <a href="{{ related_url }}">
                  <span class="guide-related__visual guide-related__visual--{{ block.settings.icon_style }}">
                    {% if related_image %}
                      {{ related_image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '280, 420, 560, 700', sizes: '(max-width: 759px) calc(100vw - 64px), 360px', alt: related_image.alt | default: related_title }}
                    {% else %}
                      <svg viewBox="0 0 64 64" aria-hidden="true"><path d="M12 18h40v28H12zM18 12v12M46 12v12M20 32h24M20 39h17" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
                    {% endif %}
                  </span>
                  <span class="guide-related__body"><strong>{{ related_title }}</strong><span>{{ related_excerpt }}</span><em>{{ section.settings.related_link_label }}</em></span>
                </a>
              </article>
            {% endif %}
          {% endfor %}
        </div>
      </aside>

      {% if featured_product != blank %}
        <aside class="guide-final">
          <div><p class="eyebrow">{{ section.settings.final_eyebrow }}</p><h2>{{ section.settings.final_heading }}</h2><p>{{ section.settings.final_text }}</p></div>
          <a class="btn btn--paper" href="{{ featured_product.url }}">{{ section.settings.final_button }}</a>
        </aside>
      {% endif %}
    </article>
  </div>
</section>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% stylesheet %}
  .guide-article {
    --guide-panel: #151518;
    --guide-panel-strong: #1b1b20;
    --guide-line: rgba(255, 255, 255, 0.11);
    --guide-muted: rgba(247, 244, 236, 0.68);
    min-height: 100vh;
    padding: 128px 0 calc(96px + env(safe-area-inset-bottom));
    overflow: clip;
    background: var(--c-bg);
    color: var(--c-paper);
    font-family: "Space Grotesk", Helvetica, Arial, sans-serif;
  }

  .guide-article .seo-breadcrumb {
    color: rgba(247, 244, 236, 0.62);
  }

  .guide-article .seo-breadcrumb [aria-current="page"] {
    color: var(--c-paper);
  }

  .guide-article__layout {
    width: min(100%, 1120px);
    margin-inline: auto;
  }

  .guide-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    gap: clamp(36px, 6vw, 84px);
    align-items: center;
    padding: clamp(24px, 4vw, 52px) 0 clamp(56px, 8vw, 96px);
  }

  .guide-badge {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 9px 14px;
    border: 1px solid var(--guide-line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--c-paper);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .guide-badge .g-dots span {
    width: 5px;
    height: 5px;
  }

  .guide-hero h1 {
    max-width: 13ch;
    margin-top: 24px;
    color: var(--c-paper);
    font-size: clamp(2.4rem, 6vw, 5.3rem);
    line-height: 0.98;
  }

  .guide-hero__dek {
    max-width: 58ch;
    margin-top: 24px;
    color: var(--guide-muted);
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    line-height: 1.55;
  }

  .guide-hero__dek p + p {
    margin-top: 0.75em;
  }

  .guide-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 22px;
    margin-top: 28px;
    color: rgba(247, 244, 236, 0.54);
    font-size: 0.88rem;
  }

  .guide-hero__meta span {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .guide-hero__meta span::before {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--g-blue);
    content: "";
  }

  .guide-hero__visual {
    position: relative;
    min-width: 0;
    min-height: 430px;
    margin: 0;
    display: grid;
    place-items: center;
    overflow: hidden;
    border: 1px solid var(--guide-line);
    border-radius: 32px;
    background: radial-gradient(circle at 30% 20%, rgba(26, 115, 232, 0.2), transparent 40%), #111114;
    box-shadow: 0 40px 90px -48px rgba(0, 0, 0, 0.95);
  }

  .guide-hero__image {
    width: 100%;
    height: 100%;
    min-height: 430px;
    object-fit: cover;
  }

  .signal-scene {
    position: relative;
    width: 100%;
    height: 430px;
  }

  .signal-scene__plaque {
    position: absolute;
    left: 9%;
    top: 50%;
    z-index: 1;
    width: 48%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 24px;
    transform: translateY(-50%) rotate(-5deg);
    box-shadow: 0 34px 70px -28px #000;
  }

  .signal-scene__phone {
    position: absolute;
    right: 10%;
    top: 50%;
    z-index: 3;
    width: 34%;
    aspect-ratio: 9 / 18;
    padding: 12px;
    border: 2px solid #36363d;
    border-radius: 32px;
    background: #08080a;
    transform: translateY(-48%) rotate(6deg);
    box-shadow: 0 38px 80px -30px #000;
  }

  .signal-scene__notch {
    width: 38%;
    height: 13px;
    display: block;
    margin: 0 auto;
    border-radius: 999px;
    background: #000;
  }

  .signal-scene__notice {
    display: flex;
    align-items: center;
    gap: 9px;
    margin-top: 28px;
    padding: 10px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    background: #242429;
    color: #fff;
  }

  .signal-scene__notice b {
    flex: 0 0 32px;
    height: 32px;
    display: grid;
    place-items: center;
    border-radius: 9px;
    background: var(--g-blue);
    font-size: 0.64rem;
  }

  .signal-scene__notice small {
    font-size: 0.62rem;
    line-height: 1.25;
  }

  .signal-scene__waves {
    position: absolute;
    left: 48%;
    top: 50%;
    z-index: 2;
    width: 150px;
    height: 150px;
    transform: translate(-50%, -50%);
  }

  .signal-scene__waves span {
    position: absolute;
    inset: 50% auto auto 50%;
    width: calc(36px + var(--wave, 0) * 44px);
    height: calc(36px + var(--wave, 0) * 44px);
    border: 2px solid rgba(102, 183, 255, calc(0.9 - var(--wave, 0) * 0.2));
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }

  .signal-scene__waves span:nth-child(2) { --wave: 1; }
  .signal-scene__waves span:nth-child(3) { --wave: 2; }

  .compare-scene {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 12px;
    align-items: center;
    padding: 26px;
  }

  .compare-scene__card {
    min-width: 0;
    min-height: 300px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 24px;
    border: 1px solid var(--guide-line);
    border-radius: 24px;
    background: #18181c;
  }

  .compare-scene__card--nfc { color: #7fc0ff; }
  .compare-scene__card--qr { color: var(--c-paper); }
  .compare-scene__card svg { width: 82px; margin-inline: auto; }
  .compare-scene__label { color: currentColor; font-size: 1.1rem; font-weight: 700; }
  .compare-scene__card small { color: var(--guide-muted); }
  .compare-scene__versus { color: rgba(255, 255, 255, 0.36); font-size: 2rem; }

  .link-scene {
    width: 100%;
    padding: 30px;
  }

  .link-scene__browser {
    overflow: hidden;
    border: 1px solid var(--guide-line);
    border-radius: 22px;
    background: #f7f5ef;
    color: #1a1a1c;
    box-shadow: 0 30px 60px -35px #000;
  }

  .link-scene__browserbar {
    display: flex;
    gap: 6px;
    padding: 13px 16px;
    border-bottom: 1px solid #dedbd4;
  }

  .link-scene__browserbar span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #b8b5af;
  }

  .link-scene__browserbar span:nth-child(1) { background: var(--g-red); }
  .link-scene__browserbar span:nth-child(2) { background: var(--g-yellow); }
  .link-scene__browserbar span:nth-child(3) { background: var(--g-green); }

  .link-scene__profile {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 28px 26px 18px;
  }

  .link-scene__avatar {
    flex: 0 0 54px;
    height: 54px;
    display: grid;
    place-items: center;
    border-radius: 14px;
    background: #111114;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .link-scene__profile > span:last-child { display: grid; }
  .link-scene__profile small { color: #69676c; }

  .link-scene__action {
    width: calc(100% - 52px);
    min-height: 46px;
    display: grid;
    place-items: center;
    margin: 0 26px 26px;
    border-radius: 999px;
    background: var(--g-blue);
    color: #fff;
    font-weight: 600;
  }

  .link-scene__url {
    position: relative;
    z-index: 2;
    min-height: 58px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin: -8px 16px 0;
