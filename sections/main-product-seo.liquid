<section class="seo-product">
  <div class="container">
    {% render 'seo-breadcrumbs', current_title: section.settings.heading %}

    <div class="seo-product__hero" data-buy>
      <div class="seo-product__media">
        {% assign main_image = product.selected_or_first_available_variant.featured_image | default: product.featured_image %}
        {% if main_image %}
          {{ main_image | image_url: width: 1400 | image_tag: class: 'seo-product__image', loading: 'eager', fetchpriority: 'high', widths: '360, 540, 750, 1000, 1400', sizes: '(max-width: 899px) calc(100vw - 32px), 52vw', alt: product.title, data-buy-image: '' }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'seo-product__image seo-product__placeholder' }}
        {% endif %}

        {% if product.images.size > 1 %}
          <div class="prod-thumbs" aria-label="{{ 'seo.product_images' | t }}">
            {% for image in product.images %}
              {% assign image_alt = image.alt | default: product.title %}
              <button
                type="button"
                class="prod-thumb{% if image.id == main_image.id %} is-active{% endif %}"
                data-buy-thumb
                data-image-id="{{ image.id }}"
                data-image-src="{{ image | image_url: width: 1400 }}"
                data-image-alt="{{ image_alt | escape }}"
                aria-label="{{ 'seo.show_image' | t: title: image_alt }}"
                aria-pressed="{% if image.id == main_image.id %}true{% else %}false{% endif %}"
              >
                {{ image | image_url: width: 160 | image_tag: loading: 'lazy', widths: '80, 120, 160', sizes: '72px', alt: image_alt }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="seo-product__purchase">
        {%- render 'google-rating-badge', variant: 'pdp', href: '#avis-google' -%}
        <h1 class="h-lg">{{ section.settings.heading }}</h1>
        {%- render 'product-reassurance' -%}
        <div class="seo-product__intro rte">{{ section.settings.intro }}</div>
        {% render 'buy-form', product: product %}
        <ul class="seo-product__trust">
          <li><a href="/pages/a-propos">Qui vend cette plaque</a></li>
          <li><a href="/pages/contact">Nous contacter</a></li>
          <li><a href="/policies/shipping-policy">Expédition</a></li>
          <li><a href="/policies/refund-policy">Retours et remboursement</a></li>
        </ul>
      </div>
    </div>

    <div class="seo-product__content" data-sp-content>
      {% assign chapter = 0 %}
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'audience' %}
            {% assign chapter = chapter | plus: 1 %}
            <section class="sp-chapter sp-lead" {{ block.shopify_attributes }}>
              <div class="sp-lead__copy">
                <p class="eyebrow sp-eyebrow"><span class="sp-index">0{{ chapter }}</span>{{ block.settings.eyebrow }}</p>
                <h2 class="sp-title">{{ block.settings.heading }}</h2>
                <p class="sp-lead__text">{{ block.settings.lead }}</p>
              </div>
              <div class="sp-lead__aside">
                {% assign chips = block.settings.chips | split: ',' %}
                <ul class="sp-chips" role="list">
                  {% for chip in chips %}<li>{{ chip | strip }}</li>{% endfor %}
                </ul>
                <div class="sp-pack">
                  <b>{{ block.settings.pack_title }}</b>
                  <p>{{ block.settings.pack_text }}</p>
                </div>
              </div>
            </section>

          {% when 'process' %}
            {% assign chapter = chapter | plus: 1 %}
            <section class="sp-chapter sp-process" {{ block.shopify_attributes }}>
              <div class="sp-head">
                <p class="eyebrow sp-eyebrow"><span class="sp-index">0{{ chapter }}</span>{{ block.settings.eyebrow }}</p>
                <h2 class="sp-title">{{ block.settings.heading }}</h2>
              </div>
              {%- comment -%}
                Un visuel par étape. Le réglage `stepN_image` est prioritaire ;
                tant qu'il est vide, l'image correspondante déjà en ligne sur le
                CDN Shopify est servie (cf. snippet sp-media).
              {%- endcomment -%}
              {%- assign sp_step_sizes = '(min-width: 900px) 30vw, calc(100vw - 48px)' -%}
              <ol class="sp-steps" role="list">
                <li>
                  {%- render 'sp-media',
                    image: block.settings.step1_image,
                    fallback_url: 'https://cdn.shopify.com/s/files/1/1058/4378/6073/files/ChatGPT_Image_13_juil._2026_14_05_27_1.png?v=1783944354',
                    alt: 'Main approchant un smartphone de la plaque NFC',
                    sizes: sp_step_sizes,
                    class: 'sp-steps__media'
                  -%}
                  <span class="sp-steps__icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="7" y="2" width="10" height="20" rx="2.4" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M10 18.4h4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></span>
                  <div>
                    <span class="sp-steps__num">Étape 1</span>
                    <h3>{{ block.settings.step1_title }}</h3>
                    <p>{{ block.settings.step1_text }}</p>
                  </div>
                </li>
                <li>
                  {%- render 'sp-media',
                    image: block.settings.step2_image,
                    fallback_url: 'https://cdn.shopify.com/s/files/1/1058/4378/6073/files/ChatGPT_Image_13_juil._2026_14_05_27_2.png?v=1783944354',
                    alt: 'Plaque prête à l’emploi, sans application ni abonnement',
                    sizes: sp_step_sizes,
                    class: 'sp-steps__media'
                  -%}
                  <span class="sp-steps__icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 15.5c3.2-3.2 3.2-6.8 0-10M10.5 18c4.8-4.8 4.8-10.2 0-15M15 20.5c6.4-6.4 6.4-13.6 0-20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></span>
                  <div>
                    <span class="sp-steps__num">Étape 2</span>
                    <h3>{{ block.settings.step2_title }}</h3>
                    <p>{{ block.settings.step2_text }}</p>
                  </div>
                </li>
                <li>
                  {%- render 'sp-media',
                    image: block.settings.step3_image,
                    fallback_url: 'https://cdn.shopify.com/s/files/1/1058/4378/6073/files/ChatGPT_Image_18_juil._2026_10_59_58.png?v=1784365218',
                    alt: 'Avis 5 étoiles en hausse pour un commerce équipé',
                    sizes: sp_step_sizes,
                    class: 'sp-steps__media'
                  -%}
                  <span class="sp-steps__icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="m12 4 2.2 4.5 5 .72-3.6 3.5.85 4.95L12 15.3l-4.45 2.37.85-4.95-3.6-3.5 5-.72z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg></span>
                  <div>
                    <span class="sp-steps__num">Étape 3</span>
                    <h3>{{ block.settings.step3_title }}</h3>
                    <p>{{ block.settings.step3_text }}</p>
                  </div>
                </li>
              </ol>
              <aside class="sp-note">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 2.8V11c0 4.4-2.9 7.9-7 9.8C7.9 18.9 5 15.4 5 11V5.8z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="m9.1 11.6 2 2 3.8-4" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <p><b>{{ block.settings.note_title }}</b> {{ block.settings.note_text }}</p>
              </aside>
            </section>

          {% when 'preparation' %}
            {% assign chapter = chapter | plus: 1 %}
            <section class="sp-chapter sp-panel sp-prep" {{ block.shopify_attributes }}>
              <div class="sp-head">
                <p class="eyebrow sp-eyebrow"><span class="sp-index">0{{ chapter }}</span>{{ block.settings.eyebrow }}</p>
                <h2 class="sp-title">{{ block.settings.heading }}</h2>
              </div>
              <ol class="sp-timeline" role="list">
                <li><b>{{ block.settings.step1_title }}</b><p>{{ block.settings.step1_text }}</p></li>
                <li><b>{{ block.settings.step2_title }}</b><p>{{ block.settings.step2_text }}</p></li>
                <li><b>{{ block.settings.step3_title }}</b><p>{{ block.settings.step3_text }}</p></li>
              </ol>
              <div class="sp-facts">
                <div><b>{{ block.settings.fact1_value }}</b><span>{{ block.settings.fact1_label }}</span></div>
                <div><b>{{ block.settings.fact2_value }}</b><span>{{ block.settings.fact2_label }}</span></div>
              </div>
              <p class="sp-mini">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12a8 8 0 0 1 13.6-5.7L20 8.5M20 12a8 8 0 0 1-13.6 5.7L4 15.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M20 4.5v4h-4M4 19.5v-4h4" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {{ block.settings.note_text }}
              </p>
            </section>

          {% when 'formats' %}
            {% assign chapter = chapter | plus: 1 %}
            <section class="sp-chapter sp-panel sp-formats" {{ block.shopify_attributes }}>
              <div class="sp-head">
                <p class="eyebrow sp-eyebrow"><span class="sp-index">0{{ chapter }}</span>{{ block.settings.eyebrow }}</p>
                <h2 class="sp-title">{{ block.settings.heading }}</h2>
              </div>
              {%- comment -%}
                Les deux pastilles ne sont plus des aplats CSS : ce sont les
                photos réelles des plaques. Le lien avec les variantes est
                conservé — chaque vignette pointe vers la variante Noir / Bleu
                correspondante, retrouvée par son titre, avec repli sur la fiche
                produit si aucune correspondance n'existe.
              {%- endcomment -%}
              {%- liquid
                assign sp_variant_noir = blank
                assign sp_variant_bleu = blank
                for sp_variant in product.variants
                  if sp_variant.title == block.settings.color1_label
                    assign sp_variant_noir = sp_variant
                  endif
                  if sp_variant.title == block.settings.color2_label
                    assign sp_variant_bleu = sp_variant
                  endif
                endfor
                assign sp_url_noir = product.url
                if sp_variant_noir != blank
                  assign sp_url_noir = product.url | append: '?variant=' | append: sp_variant_noir.id
                endif
                assign sp_url_bleu = product.url
                if sp_variant_bleu != blank
                  assign sp_url_bleu = product.url | append: '?variant=' | append: sp_variant_bleu.id
                endif
                assign sp_swatch_sizes = '(min-width: 900px) 17vw, (min-width: 640px) calc(50vw - 40px), calc(100vw - 80px)'
              -%}
              <p class="sp-size">{{ block.settings.size_value }}<small>{{ block.settings.size_label }}</small></p>
              <div class="sp-swatches">
                <a class="sp-swatch sp-swatch--noir" href="{{ sp_url_noir }}">
                  {%- render 'sp-media',
                    image: block.settings.color1_image,
                    fallback_url: 'https://cdn.shopify.com/s/files/1/1058/4378/6073/files/ChatGPT_Image_13_juil._2026_13_55_19_1.png?v=1783943744',
                    alt: 'Plaque NFC avis Google, modèle noir',
                    sizes: sp_swatch_sizes,
                    class: 'sp-swatch__media'
                  -%}
                  <span>{{ block.settings.color1_label }}</span>
                </a>
                <a class="sp-swatch sp-swatch--bleu" href="{{ sp_url_bleu }}">
                  {%- render 'sp-media',
                    image: block.settings.color2_image,
                    fallback_url: 'https://cdn.shopify.com/s/files/1/1058/4378/6073/files/ChatGPT_Image_13_juil._2026_13_55_19_2.png?v=1783943744',
                    alt: 'Plaque NFC avis Google, modèle bleu',
                    sizes: sp_swatch_sizes,
                    class: 'sp-swatch__media'
                  -%}
                  <span>{{ block.settings.color2_label }}</span>
                </a>
              </div>
              <p class="sp-formats__text">{{ block.settings.pack_text }}</p>
              <aside class="sp-note">
                <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.5" cy="12" r="7" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="10.5" cy="12" r="2.4" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M17.5 12H21" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
                <p><b>{{ block.settings.adhesive_title }}</b> {{ block.settings.adhesive_text }}</p>
              </aside>
            </section>

          {% when 'compatibility' %}
            {% assign chapter = chapter | plus: 1 %}
            <section class="sp-chapter sp-compat" {{ block.shopify_attributes }}>
              <div class="sp-head">
                <p class="eyebrow sp-eyebrow"><span class="sp-index">0{{ chapter }}</span>{{ block.settings.eyebrow }}</p>
                <h2 class="sp-title">{{ block.settings.heading }}</h2>
              </div>
              {%- comment -%}
                Les silhouettes de téléphones sont remplacées par les logos des
                deux marques, en SVG inline monochrome : la couleur est héritée
                du thème (currentColor), aucun fichier image n'est chargé.
              {%- endcomment -%}
              <div class="sp-compat-grid">
                <div class="sp-device">
                  <b>{%- render 'icon-apple', class: 'sp-device__logo' -%}{{ block.settings.device1_name }}</b>
                  <p>{{ block.settings.device1_text }}</p>
                </div>
                <div class="sp-device">
                  <b>{%- render 'icon-samsung', class: 'sp-device__logo' -%}{{ block.settings.device2_name }}</b>
                  <p>{{ block.settings.device2_text }}</p>
                </div>
                <aside class="sp-limits">
                  <b>{{ block.settings.limits_title }}</b>
                  <p>{{ block.settings.limits_text }}</p>
                </aside>
              </div>
            </section>

          {% when 'install' %}
            {% assign chapter = chapter | plus: 1 %}
            <section class="sp-chapter sp-install" {{ block.shopify_attributes }}>
              <div class="sp-head">
                <p class="eyebrow sp-eyebrow"><span class="sp-index">0{{ chapter }}</span>{{ block.settings.eyebrow }}</p>
                <h2 class="sp-title">{{ block.settings.heading }}</h2>
              </div>
              <div class="install-grid sp-install30">
                {% for step_index in (1..3) %}
                  {% liquid
                    case step_index
                      when 1
                        assign step_title = block.settings.step1_title
                        assign step_text = block.settings.step1_text
                      when 2
                        assign step_title = block.settings.step2_title
                        assign step_text = block.settings.step2_text
                      else
                        assign step_title = block.settings.step3_title
                        assign step_text = block.settings.step3_text
                    endcase
                  %}
                  <div class="install-step">
                    <figure class="install-img">
                      <picture>
                        <source media="(max-width: 760px)" srcset="{{ step_index | append: '-mobile.jpg' | asset_url }}">
                        <source type="image/webp" srcset="{{ step_index | append: '-480.webp' | asset_url }} 480w, {{ step_index | append: '-760.webp' | asset_url }} 760w, {{ step_index | append: '-1000.webp' | asset_url }} 1000w" sizes="(max-width: 760px) calc(100vw - 32px), 33vw">
                        <img src="{{ step_index | append: '.png' | asset_url }}" width="1254" height="1254" loading="lazy" alt="{{ step_title | escape }}">
                      </picture>
                    </figure>
                    <span class="num">ÉTAPE 0{{ step_index }}</span>
                    <h3>{{ step_title }}</h3>
                    <p>{{ step_text }}</p>
                  </div>
                {% endfor %}
              </div>
              <aside class="sp-shipping sp-shipping--row">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2.5 6.5h11v10h-11zM13.5 10h4.2l3.3 3.2v3.3h-7.5z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><circle cx="6.8" cy="18.6" r="1.9" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="16.8" cy="18.6" r="1.9" fill="none" stroke="currentColor" stroke-width="1.7"/></svg>
                <b>{{ block.settings.shipping_title }}</b>
                <div class="sp-shipping__cols">
                  <p>{{ block.settings.shipping_lead }}</p>
                  <p>{{ block.settings.shipping_text }}</p>
                </div>
              </aside>
            </section>

          {% when 'content' %}
            <section class="seo-product__panel" {{ block.shopify_attributes }}>
              {% if block.settings.eyebrow != blank %}<p class="eyebrow">{{ block.settings.eyebrow }}</p>{% endif %}
              <h2>{{ block.settings.heading }}</h2>
              <div class="seo-prose rte">{{ block.settings.body }}</div>
            </section>
        {% endcase %}
      {% endfor %}

      {%- comment -%}
        Emplacement 4 — section complète des avis, juste avant la FAQ.
        Même snippet que la section d'accueil : un seul balisage à maintenir.
      {%- endcomment -%}
      {%- render 'google-reviews-block',
        title: section.settings.reviews_title,
        source_note: section.settings.reviews_source_note,
        google_link: section.settings.reviews_google_link,
        initial_count: section.settings.reviews_initial_count
      -%}

      {% assign has_faq = false %}
      {% for block in section.blocks %}
        {% if block.type == 'faq' %}{% assign has_faq = true %}{% endif %}
      {% endfor %}
      {% if has_faq %}
        <section class="seo-product__faq">
          <p class="eyebrow">{{ section.settings.faq_eyebrow }}</p>
          <h2>{{ section.settings.faq_heading }}</h2>
          <div class="seo-faq-list">
            {% for block in section.blocks %}
              {% if block.type == 'faq' %}
                <details {{ block.shopify_attributes }}>
                  <summary><h3>{{ block.settings.question }}</h3><span aria-hidden="true">+</span></summary>
                  <div class="seo-prose rte">{{ block.settings.answer }}</div>
                </details>
              {% endif %}
            {% endfor %}
          </div>
        </section>
      {% endif %}
    </div>
  </div>
</section>

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

{% stylesheet %}
  .seo-product {
    min-height: 100vh;
    padding: 128px 0 96px;
    background: var(--c-bg);
    color: var(--c-paper);
  }

  /* La piste implicite d'une grille est `auto` : elle ne descend jamais sous le
     min-content de ses items. `.prod-thumbs` est un conteneur flex dont les
     miniatures sont inflexibles (`flex:0 0 58/72px`), ce qui lui donne un
     min-content de ~404 px ; il remontait tel quel jusqu'ici et élargissait
     toute la page sous ~415 px de large (bande blanche à droite).
     Piste explicite `minmax(0, 1fr)` + `min-width: 0` sur les items : la colonne
     peut désormais rétrécir sous le min-content de son contenu. Les miniatures
     gardent leur propre `overflow-x: auto` et défilent toujours à l'intérieur de
     leur cadre — elles ne peuvent simplement plus pousser le document. */
  .seo-product__hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 32px;
  }

  .seo-product__media,
  .seo-product__purchase {
    min-width: 0;
  }

  .seo-product__image,
  .seo-product__placeholder {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 26px;
    background: #141416;
  }

  .seo-product__purchase h1 {
    margin-top: 14px;
    color: var(--c-paper);
  }

  .seo-product__intro {
    max-width: 62ch;
    margin: 20px 0 30px;
    color: color-mix(in srgb, var(--c-paper) 72%, transparent);
    font-size: 1.05rem;
  }

  .seo-product__purchase .buy-form-col {
    padding: 0;
    border: 0;
    background: transparent;
  }

  .seo-product__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 22px;
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.11);
    list-style: none;
  }

  .seo-product__trust a {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    color: color-mix(in srgb, var(--c-paper) 62%, transparent);
    font-size: 0.86rem;
    text-underline-offset: 4px;
  }

  .seo-product__trust a:hover,
  .seo-product__trust a:focus-visible {
    color: var(--c-paper);
  }

  /* ---- Composition éditoriale ---- */

  .seo-product__content {
    --sp-line: rgba(255, 255, 255, 0.11);
    --sp-panel: #151518;
    --sp-panel-2: #101012;
    --sp-muted: rgba(247, 244, 236, 0.68);
    --sp-blue-soft: #8bc0ff;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(52px, 9vw, 80px) 20px;
    margin-top: clamp(72px, 10vw, 104px);
    font-family: "Space Grotesk", Helvetica, Arial, sans-serif;
  }

  .sp-chapter {
    min-width: 0;
  }

  .sp-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .sp-index {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--sp-blue-soft);
    font-weight: 600;
  }

  .sp-index::after {
    width: 26px;
    height: 1px;
    background: color-mix(in srgb, var(--g-blue) 55%, transparent);
    content: "";
  }

  .sp-title {
    max-width: 24ch;
    margin-top: 12px;
    color: var(--c-paper);
    font-size: clamp(1.65rem, 5.6vw, 2.6rem);
    line-height: 1.06;
    letter-spacing: -0.015em;
  }

  .sp-panel {
    padding: clamp(22px, 4.5vw, 40px);
    border: 1px solid var(--sp-line);
    border-radius: 26px;
    background: var(--sp-panel);
  }

  /* 01 — bloc principal commerces */
  .sp-lead {
    display: grid;
    gap: 30px;
    padding: clamp(24px, 5vw, 52px);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--g-blue) 30%, transparent);
    border-radius: 30px;
    background:
      radial-gradient(circle at 10% -10%, color-mix(in srgb, var(--g-blue) 17%, transparent), transparent 46%),
      #121215;
  }

  .sp-lead__text {
    max-width: 52ch;
    margin-top: 18px;
    color: var(--sp-muted);
    font-size: 1.05rem;
    line-height: 1.62;
  }

  .sp-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .sp-chips li {
    padding: 9px 14px;
    border: 1px solid var(--sp-line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.045);
    color: var(--c-paper);
    font-size: 0.86rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .sp-pack {
    display: grid;
    gap: 8px;
    margin-top: 18px;
    padding: 18px 20px;
    border: 1px solid color-mix(in srgb, var(--g-blue) 38%, transparent);
    border-radius: 18px;
    background: color-mix(in srgb, var(--g-blue) 9%, transparent);
  }

  .sp-pack b {
    color: var(--sp-blue-soft);
  }

  .sp-pack p {
    color: var(--sp-muted);
    font-size: 0.94rem;
    line-height: 1.52;
  }

  /* 02 — étapes NFC */
  .sp-steps {
    display: grid;
    gap: 12px;
    margin: 28px 0 0;
    padding: 0;
    list-style: none;
  }

  .sp-steps li {
    display: grid;
    grid-template-columns: 46px minmax(0, 1fr);
    gap: 16px;
    padding: 20px;
    border: 1px solid var(--sp-line);
    border-radius: 20px;
    background: var(--sp-panel);
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  /* Visuel d'étape : il occupe toute la largeur de la carte, y compris sous
     900 px où `.sp-steps li` est une grille à deux colonnes (icône + texte).
     Le ratio est imposé en CSS, donc aucun saut de mise en page au chargement,
     quelle que soit l'image choisie dans l'éditeur. */
  .sp-media {
    margin: 0;
  }

  .sp-steps__media {
    grid-column: 1 / -1;
    margin-bottom: 18px;
    overflow: hidden;
    border-radius: 16px;
    background: var(--sp-panel-2);
    aspect-ratio: 1 / 1;
  }

  .sp-steps__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sp-steps__icon {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border: 1px solid var(--sp-line);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--sp-blue-soft);
  }

  .sp-steps__icon svg {
    width: 22px;
    height: 22px;
  }

  .sp-steps__num {
    color: rgba(247, 244, 236, 0.42);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .sp-steps h3 {
    margin-top: 6px;
    color: var(--c-paper);
    font-size: 1.08rem;
    line-height: 1.2;
  }

  .sp-steps p {
    margin-top: 8px;
    color: var(--sp-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .sp-note {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin-top: 16px;
    padding: 18px 20px;
    border: 1px solid var(--sp-line);
    border-left: 3px solid var(--g-blue);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.03);
  }

  .sp-note svg {
    flex: 0 0 22px;
    width: 22px;
    height: 22px;
    margin-top: 1px;
    color: var(--sp-blue-soft);
  }

  .sp-note p {
    color: var(--sp-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .sp-note b {
    color: var(--c-paper);
  }

  /* 03 — préparation, timeline */
  .sp-timeline {
    margin: 26px 0 22px;
    padding: 0;
    list-style: none;
  }

  .sp-timeline li {
    position: relative;
    padding: 0 0 24px 32px;
  }

  .sp-timeline li:last-child {
    padding-bottom: 0;
  }

  .sp-timeline li::before {
    position: absolute;
    left: 8px;
    top: 10px;
    bottom: -4px;
    width: 1px;
    background: var(--sp-line);
    content: "";
  }

  .sp-timeline li:last-child::before {
    display: none;
  }

  .sp-timeline li::after {
    position: absolute;
    left: 4px;
    top: 7px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--g-blue);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--g-blue) 22%, transparent);
    content: "";
  }

  .sp-timeline b {
    color: var(--c-paper);
    font-size: 1.04rem;
  }

  .sp-timeline p {
    margin-top: 6px;
    color: var(--sp-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .sp-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .sp-facts > div {
    padding: 16px 18px;
    border: 1px solid var(--sp-line);
    border-radius: 16px;
    background: var(--sp-panel-2);
  }

  .sp-facts b {
    display: block;
    color: var(--sp-blue-soft);
    font-size: clamp(1.7rem, 6vw, 2.2rem);
    line-height: 1;
  }

  .sp-facts span {
    display: block;
    margin-top: 7px;
    color: var(--sp-muted);
    font-size: 0.85rem;
    line-height: 1.35;
  }

  .sp-mini {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin-top: 16px;
    color: var(--sp-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .sp-mini svg {
    flex: 0 0 18px;
    width: 18px;
    height: 18px;
    margin-top: 2px;
    color: var(--sp-blue-soft);
  }

  /* 04 — formats */
  .sp-size {
    margin: 24px 0 4px;
    color: var(--c-paper);
    font-size: clamp(2.5rem, 10vw, 3.4rem);
    font-weight: 600;
    line-height: 0.95;
    letter-spacing: -0.02em;
  }

  .sp-size small {
    display: block;
    margin-top: 8px;
    color: rgba(247, 244, 236, 0.45);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  /* Deux modeles, donc deux pastilles : une colonne sur mobile, deux colonnes
     equilibrees des 640 px (regle plus bas). `align-items:stretch` par defaut :
     les deux cartes ont exactement la meme hauteur quel que soit le libelle. */
  .sp-swatches {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 12px;
    margin-top: 22px;
  }

  /* Les pastilles ne sont plus des aplats de couleur : chacune porte la photo
     réelle du modèle et pointe vers sa variante. `display:block` + `color:inherit`
     neutralisent le style de lien hérité (a:hover passait en bleu). */
  .sp-swatch {
    display: block;
    overflow: hidden;
    border: 1px solid var(--sp-line);
    border-radius: 18px;
    background: var(--sp-panel-2);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  .sp-swatch:hover {
    color: inherit;
    border-color: var(--g-blue);
  }

  /* Cadre carre identique pour les deux modeles, et `object-fit: contain` :
     la plaque est toujours visible en entier, sans recadrage, y compris si une
     image non carree est choisie plus tard depuis l'editeur. */
  .sp-swatch__media {
    aspect-ratio: 1 / 1;
    background: #0a0a0c;
  }

  .sp-swatch__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .sp-swatch > span:last-child {
    display: block;
    padding: 10px 14px;
    border-top: 1px solid var(--sp-line);
    color: var(--c-paper);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .sp-formats__text {
    margin: 18px 0 0;
    color: var(--sp-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  /* 05 — compatibilité */
  .sp-compat-grid {
    display: grid;
    gap: 12px;
    margin-top: 26px;
  }

  .sp-device {
    padding: 22px;
    border: 1px solid var(--sp-line);
    border-radius: 20px;
    background: var(--sp-panel-2);
    transition: border-color 0.25s ease;
  }

  /* Logo + nom de la marque : centrés sur mobile, alignés à gauche (donc
     horizontalement, côte à côte) dès 640 px où la grille passe en colonnes. */
  .sp-device b {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: var(--c-paper);
    font-size: 1.05rem;
    text-align: center;
  }

  .sp-device__logo {
    flex: 0 0 auto;
    width: auto;
    height: 24px;
    color: var(--c-paper);
  }

  .sp-device__logo--samsung {
    height: 20px;
  }

  .sp-device p {
    margin-top: 10px;
    color: var(--sp-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .sp-limits {
    padding: 22px;
    border: 1px solid rgba(251, 188, 4, 0.32);
    border-radius: 20px;
    background: rgba(251, 188, 4, 0.07);
  }

  .sp-limits b {
    color: var(--c-paper);
  }

  .sp-limits p {
    margin-top: 10px;
    color: var(--sp-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  /* 06 — installation et livraison (reprise de la section accueil, variante sombre) */
  .sp-install .sp-install30 {
    margin-top: 30px;
  }

  .sp-install30 .install-step {
    border-top-color: rgba(255, 255, 255, 0.16);
  }

  .sp-install30 .install-step .num {
    color: rgba(247, 244, 236, 0.45);
  }

  .sp-install30 .install-step h3 {
    color: var(--c-paper);
  }

  .sp-install30 .install-step p {
    color: var(--sp-muted);
  }

  .sp-install30 .install-img {
    background: #141416;
  }

  .sp-shipping--row {
    margin-top: 22px;
  }

  .sp-shipping {
    padding: clamp(22px, 4vw, 32px);
    border: 1px solid color-mix(in srgb, var(--g-blue) 32%, transparent);
    border-radius: 22px;
    background:
      radial-gradient(circle at 88% 0%, color-mix(in srgb, var(--g-blue) 18%, transparent), transparent 55%),
      #121215;
  }

  .sp-shipping svg {
    width: 30px;
    height: 30px;
    color: var(--sp-blue-soft);
  }

  .sp-shipping b {
    display: block;
    margin-top: 14px;
    color: var(--c-paper);
    font-size: 1.18rem;
  }

  .sp-shipping p {
    margin-top: 10px;
    color: var(--sp-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .sp-shipping__cols {
    display: grid;
  }

  /* révélation au scroll (classe ajoutée en JS uniquement) */
  .sp-reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.55s ease, transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .sp-reveal.is-in {
    opacity: 1;
    transform: none;
  }

  /* panneau générique + FAQ */
  .seo-product__panel,
  .seo-product__faq {
    padding: 28px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    background: #131315;
  }

  .seo-product__panel h2,
  .seo-product__faq h2 {
    margin-top: 10px;
    color: var(--c-paper);
    font-size: clamp(1.65rem, 5vw, 2.5rem);
  }

  .seo-prose {
    max-width: 72ch;
    margin-top: 18px;
    color: color-mix(in srgb, var(--c-paper) 72%, transparent);
  }

  .seo-prose > * + *,
  .rte > * + * {
    margin-top: 1em;
  }

  .seo-prose a,
  .rte a {
    color: var(--g-blue);
    text-underline-offset: 3px;
  }

  .seo-prose ul,
  .seo-prose ol {
    padding-left: 1.25rem;
  }

  .seo-faq-list {
    margin-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .seo-faq-list details {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .seo-faq-list summary {
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    cursor: pointer;
    list-style: none;
  }

  .seo-faq-list summary::-webkit-details-marker {
    display: none;
  }

  .seo-faq-list summary h3 {
    font-size: 1.05rem;
    line-height: 1.35;
    letter-spacing: -0.015em;
  }

  .seo-faq-list summary span {
    flex: 0 0 44px;
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    color: var(--g-blue);
    font-size: 1.5rem;
  }

  .seo-faq-list details[open] summary span {
    transform: rotate(45deg);
  }

  .seo-faq-list .seo-prose {
    padding: 0 0 24px;
  }

  @media (min-width: 640px) {
    .sp-shipping__cols {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0 32px;
    }

    .sp-compat-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    /* Noir et Bleu passent sur deux colonnes de largeur egale. */
    .sp-swatches {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

  /* Les deux marques passent côte à côte : le logo reprend sa place à gauche
     du nom, aligné sur le texte de la carte. */
    .sp-device b {
      justify-content: flex-start;
      text-align: left;
    }

    .sp-limits {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 900px) {
    .seo-product {
      padding-top: 150px;
      padding-bottom: 128px;
    }

    .seo-product__hero {
      grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
      gap: 64px;
      align-items: start;
    }

    .seo-product__media {
      --spm-h: calc(min((100vw - 112px) * 0.54, 635px) + 96px);
      position: sticky;
      top: max(104px, calc((100vh - var(--spm-h)) / 2));
      top: max(104px, calc((100svh - var(--spm-h)) / 2));
      align-self: start;
    }

    .seo-product__content {
      grid-template-columns: repeat(12, minmax(0, 1fr));
    }

    .seo-product__content > * {
      grid-column: 1 / -1;
    }

    .sp-lead {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.92fr);
      gap: clamp(36px, 5vw, 72px);
      align-items: center;
    }

    /* Les trois cartes forment une rangée strictement alignée : une seule piste
       de grille (`grid-auto-rows: 1fr`) dont la hauteur est celle de la carte la
       plus haute, et des items étirés dessus. Aucune hauteur en dur : elle reste
       dictée par le contenu le plus long.

       La carte 2 portait un `margin-top: 26px` décoratif. Comme la marge est
       prise dans la zone de grille, elle la descendait de 26 px ET lui retirait
       26 px de hauteur — d'où les bords hauts et bas désalignés. Elle est
       supprimée ; `margin: 0` verrouille le comportement. */
    .sp-steps {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      grid-auto-rows: 1fr;
      align-items: stretch;
      gap: 16px;
    }

    /* `align-content: start` : la hauteur excédentaire de la carte reste en bas
       au lieu d'être répartie sur les pistes. Sans cela, le `stretch` par défaut
       étirerait la piste du visuel — dont la hauteur découle d'un
       `aspect-ratio` — et les trois images n'auraient plus la même hauteur.
       Ici le visuel, l'icône, « Étape N » et le titre restent à l'identique
       d'une carte à l'autre ; seul le vide sous le paragraphe varie. */
    .sp-steps li {
      grid-template-columns: minmax(0, 1fr);
      align-content: start;
      padding: 26px;
      margin: 0;
      height: 100%;
      align-self: stretch;
    }

    .sp-steps__icon {
      margin-bottom: 22px;
    }

    .sp-prep {
      grid-column: 1 / 8;
      align-self: start;
    }

    .sp-formats {
      grid-column: 8 / -1;
      align-self: start;
    }

    .sp-compat-grid {
      grid-template-columns: minmax(0, 0.75fr) minmax(0, 0.75fr) minmax(0, 1.5fr);
    }

    .sp-limits {
      grid-column: auto;
    }

    .sp-note {
      margin-top: 20px;
    }
  }

  @media (max-width: 560px) {
    .seo-product {
      padding-top: 112px;
      padding-bottom: 72px;
    }

    .seo-product .container {
      width: min(100% - 32px, 1240px);
    }

    .seo-product__panel,
    .seo-product__faq {
      padding: 22px;
      border-radius: 20px;
    }

    .sp-lead {
      border-radius: 24px;
    }

    .sp-chips li {
      padding: 8px 12px;
      font-size: 0.82rem;
    }

  }

  @media (max-width: 374px) {
    .sp-facts {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (hover: hover) {
    .sp-steps li:hover,
    .sp-swatch:hover,
    .sp-device:hover {
      border-color: color-mix(in srgb, var(--g-blue) 45%, transparent);
    }

    .sp-steps li:hover {
      transform: translateY(-3px);
    }

    .sp-chips li:hover {
      border-color: rgba(255, 255, 255, 0.3);
      background: rgba(255, 255, 255, 0.08);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sp-steps li,
    .sp-swatch,
    .sp-device,
    .sp-chips li,
    .sp-reveal {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const root = document.querySelector('[data-sp-content]');
    if (!root) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (!('IntersectionObserver' in window)) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-in');
          io.unobserve(entry.target);
        });
      },
      { rootMargin: '0px 0px -8%', threshold: 0.06 }
    );

    root.querySelectorAll(':scope > *').forEach((el) => {
      el.classList.add('sp-reveal');
      io.observe(el);
    });
  })();
{% endjavascript %}

