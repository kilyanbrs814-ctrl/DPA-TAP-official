<section class="seo-product">
  <div class="container">
    {% render 'seo-breadcrumbs', current_title: section.settings.heading %}

    <div class="seo-product__hero" data-buy>
      <div class="seo-product__media">
        {% assign main_image = product.selected_or_first_available_variant.featured_image | default: product.featured_image %}
        {% if main_image %}
          {{ main_image | image_url: width: 1400 | image_tag: class: 'seo-product__image', loading: 'eager', fetchpriority: 'high', widths: '360, 540, 750, 1000, 1400', sizes: '(max-width: 899px) calc(100vw - 32px), 52vw', alt: product.title, data-buy-image: '' }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'seo-product__image seo-product__placeholder' }}
        {% endif %}

        {% if product.images.size > 1 %}
          <div class="prod-thumbs" aria-label="{{ 'seo.product_images' | t }}">
            {% for image in product.images %}
              {% assign image_alt = image.alt | default: product.title %}
              <button
                type="button"
                class="prod-thumb{% if image.id == main_image.id %} is-active{% endif %}"
                data-buy-thumb
                data-image-id="{{ image.id }}"
                data-image-src="{{ image | image_url: width: 1400 }}"
                data-image-alt="{{ image_alt | escape }}"
                aria-label="{{ 'seo.show_image' | t: title: image_alt }}"
                aria-pressed="{% if image.id == main_image.id %}true{% else %}false{% endif %}"
              >
                {{ image | image_url: width: 160 | image_tag: loading: 'lazy', widths: '80, 120, 160', sizes: '72px', alt: image_alt }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="seo-product__purchase">
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h1 class="h-lg">{{ section.settings.heading }}</h1>
        <div class="seo-product__intro rte">{{ section.settings.intro }}</div>
        {% render 'buy-form', product: product %}
      </div>
    </div>

    <div class="seo-product__content">
      {% for block in section.blocks %}
        {% if block.type == 'content' %}
          <section class="seo-product__panel" {{ block.shopify_attributes }}>
            {% if block.settings.eyebrow != blank %}<p class="eyebrow">{{ block.settings.eyebrow }}</p>{% endif %}
            <h2>{{ block.settings.heading }}</h2>
            <div class="seo-prose rte">{{ block.settings.body }}</div>
          </section>
        {% endif %}
      {% endfor %}

      {% assign has_faq = false %}
      {% for block in section.blocks %}
        {% if block.type == 'faq' %}{% assign has_faq = true %}{% endif %}
      {% endfor %}
      {% if has_faq %}
        <section class="seo-product__faq">
          <p class="eyebrow">{{ section.settings.faq_eyebrow }}</p>
          <h2>{{ section.settings.faq_heading }}</h2>
          <div class="seo-faq-list">
            {% for block in section.blocks %}
              {% if block.type == 'faq' %}
                <details {{ block.shopify_attributes }}>
                  <summary><h3>{{ block.settings.question }}</h3><span aria-hidden="true">+</span></summary>
                  <div class="seo-prose rte">{{ block.settings.answer }}</div>
                </details>
              {% endif %}
            {% endfor %}
          </div>
        </section>
      {% endif %}
    </div>
  </div>
</section>

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

{% stylesheet %}
  .seo-product {
    min-height: 100vh;
    padding: 128px 0 96px;
    background: var(--c-bg);
    color: var(--c-paper);
  }

  .seo-product__hero {
    display: grid;
    gap: 32px;
  }

  .seo-product__image,
  .seo-product__placeholder {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 26px;
    background: #141416;
  }

  .seo-product__purchase h1 {
    margin-top: 14px;
    color: var(--c-paper);
  }

  .seo-product__intro {
    max-width: 62ch;
    margin: 20px 0 30px;
    color: color-mix(in srgb, var(--c-paper) 72%, transparent);
    font-size: 1.05rem;
  }

  .seo-product__purchase .buy-form-col {
    padding: 0;
    border: 0;
    background: transparent;
  }

  .seo-product__content {
    display: grid;
    gap: 24px;
    margin-top: 72px;
  }

  .seo-product__panel,
  .seo-product__faq {
    padding: 28px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    background: #131315;
  }

  .seo-product__panel h2,
  .seo-product__faq h2 {
    margin-top: 10px;
    color: var(--c-paper);
    font-size: clamp(1.65rem, 5vw, 2.5rem);
  }

  .seo-prose {
    max-width: 72ch;
    margin-top: 18px;
    color: color-mix(in srgb, var(--c-paper) 72%, transparent);
  }

  .seo-prose > * + *,
  .rte > * + * {
    margin-top: 1em;
  }

  .seo-prose a,
  .rte a {
    color: var(--g-blue);
    text-underline-offset: 3px;
  }

  .seo-prose ul,
  .seo-prose ol {
    padding-left: 1.25rem;
  }

  .seo-faq-list {
    margin-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .seo-faq-list details {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .seo-faq-list summary {
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    cursor: pointer;
    list-style: none;
  }

  .seo-faq-list summary::-webkit-details-marker {
    display: none;
  }

  .seo-faq-list summary h3 {
    font-size: 1.05rem;
    line-height: 1.35;
    letter-spacing: -0.015em;
  }

  .seo-faq-list summary span {
    flex: 0 0 44px;
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    color: var(--g-blue);
    font-size: 1.5rem;
  }

  .seo-faq-list details[open] summary span {
    transform: rotate(45deg);
  }

  .seo-faq-list .seo-prose {
    padding: 0 0 24px;
  }

  @media (min-width: 900px) {
    .seo-product {
      padding-top: 150px;
      padding-bottom: 128px;
    }

    .seo-product__hero {
      grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
      gap: 64px;
      align-items: start;
    }

    .seo-product__purchase {
      position: sticky;
      top: 120px;
    }

    .seo-product__content {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .seo-product__faq {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 560px) {
    .seo-product {
      padding-top: 112px;
      padding-bottom: 72px;
    }

    .seo-product .container {
      width: min(100% - 32px, 1240px);
    }

    .seo-product__panel,
    .seo-product__faq {
      padding: 22px;
      border-radius: 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Produit SEO",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Surtitre", "default": "Plaque NFC professionnelle" },
    { "type": "text", "id": "heading", "label": "H1", "default": "Plaque NFC Avis Google pour Commerce" },
    { "type": "richtext", "id": "intro", "label": "Introduction", "default": "<p>Une plaque NFC prête à l’emploi pour ouvrir directement la page d’avis Google de votre établissement depuis un smartphone compatible. Personnalisation, programmation et achat sans abonnement.</p>" },
    { "type": "text", "id": "faq_eyebrow", "label": "Surtitre FAQ", "default": "Questions fréquentes" },
    { "type": "text", "id": "faq_heading", "label": "Titre FAQ", "default": "Ce qu’il faut savoir avant de commander" }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "Section de contenu",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Surtitre" },
        { "type": "text", "id": "heading", "label": "H2" },
        { "type": "richtext", "id": "body", "label": "Contenu" }
      ]
    },
    {
      "type": "faq",
      "name": "Question fréquente",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Réponse" }
      ]
    }
  ]
}
{% endschema %}
