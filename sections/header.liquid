<header class="hdr" data-header>
  <a class="hdr-logo" href="{{ routes.root_url }}" aria-label="{{ section.settings.logo_text | default: 'DPA TAP' }} — accueil">
    <img src="{{ 'logo-dpa-tap-white.png' | asset_url }}" alt="{{ section.settings.logo_text | default: 'DPA TAP' }}" width="414" height="84">
  </a>
  <nav class="hdr-nav" aria-label="Navigation principale">
    <a href="{{ section.settings.link_product | default: '/products/plaque-nfc-avis-google' }}">{{ section.settings.label_product | default: 'Plaque NFC' }}</a>
    <a href="{{ section.settings.link_how | default: '/#fonctionnement' }}">{{ section.settings.label_how | default: 'Fonctionnement' }}</a>
    <a href="{{ section.settings.link_models | default: '/#modeles' }}">{{ section.settings.label_models | default: 'Modèles' }}</a>
    <a href="{{ section.settings.link_faq | default: '/#faq' }}">{{ section.settings.label_faq | default: 'FAQ' }}</a>
  </nav>
  <details class="hdr-menu">
    <summary>
      <span class="sr-only">Ouvrir le menu</span>
      <span class="hdr-menu-icon" aria-hidden="true"><span></span><span></span></span>
    </summary>
    <nav class="hdr-menu-nav" aria-label="Navigation mobile">
      <a href="{{ section.settings.link_product | default: '/products/plaque-nfc-avis-google' }}">{{ section.settings.label_product | default: 'Plaque NFC' }}</a>
      <a href="{{ section.settings.link_how | default: '/#fonctionnement' }}">{{ section.settings.label_how | default: 'Fonctionnement' }}</a>
      <a href="{{ section.settings.link_models | default: '/#modeles' }}">{{ section.settings.label_models | default: 'Modèles' }}</a>
      <a href="{{ section.settings.link_faq | default: '/#faq' }}">{{ section.settings.label_faq | default: 'FAQ' }}</a>
    </nav>
  </details>
  <a class="hdr-cart" href="{{ routes.cart_url }}">
    <svg class="hdr-cart-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 4h2l2.2 10.1a2 2 0 0 0 2 1.6h7.9a2 2 0 0 0 1.9-1.4L21 8H7M10 20h.01M18 20h.01" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <span class="hdr-cart-label">Panier</span>
    <span data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
  </a>
</header>

{% schema %}
{
  "name": "En-tête",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Nom (texte alternatif du logo)", "default": "DPA TAP" },
    { "type": "text", "id": "label_product", "label": "Libellé — produit", "default": "Plaque NFC" },
    { "type": "url", "id": "link_product", "label": "Lien — produit" },
    { "type": "text", "id": "label_how", "label": "Libellé — fonctionnement", "default": "Fonctionnement" },
    { "type": "url", "id": "link_how", "label": "Lien — fonctionnement" },
    { "type": "text", "id": "label_models", "label": "Libellé — modèles", "default": "Modèles" },
    { "type": "url", "id": "link_models", "label": "Lien — modèles" },
    { "type": "text", "id": "label_faq", "label": "Libellé — FAQ", "default": "FAQ" },
    { "type": "url", "id": "link_faq", "label": "Lien — FAQ" }
  ]
}
{% endschema %}
