<section class="buy-sec" id="modeles">
  <div class="container">
    <div class="buy-head">
      {%- comment -%}
        Une ligne = un réglage = un bloc. Le <br> est remplacé par deux <span>
        en `display:block; white-space:nowrap` (cf. .buy-title-line dans
        theme.css) : chaque ligne garde la sienne et ne se replie jamais.
      {%- endcomment -%}
      <h2 class="h-xl reveal"><span class="buy-title-line">{{ section.settings.title_line1 | default: 'Deux designs.' }}</span><span class="buy-title-line">{{ section.settings.title_line2 | default: 'Un même impact.' }}</span></h2>
      <p class="reveal">{{ section.settings.text | default: 'Midnight Black pour les comptoirs affirmés, Google Blue pour les enseignes lumineuses. Les deux embarquent la même puce NFC, programmée pour vous.' }}</p>
    </div>
    {% assign product = section.settings.product %}
    {% if product != blank %}
      <div class="buy-grid" data-buy>
        <div class="reveal buy-media">
          {% assign main_img = product.selected_or_first_available_variant.featured_image | default: product.featured_image %}
          {% if main_img %}
            {{ main_img | image_url: width: 1400 | image_tag: class: 'prod-media-img', loading: 'lazy', widths: '360, 540, 750, 1000, 1400', sizes: '(max-width: 980px) calc(100vw - 32px), 55vw', alt: product.title, data-buy-image: '', style: 'border-radius:26px;width:100%' }}
          {% else %}
            <img src="{{ 'plaque-noire.jpg' | asset_url }}" width="1254" height="1254" data-buy-image loading="lazy" alt="{{ product.title | escape }}" style="border-radius:26px;width:100%">
          {% endif %}
          {% if product.images.size > 1 %}
            <div class="prod-thumbs" aria-label="Images du produit">
              {% for image in product.images %}
                {% assign thumb_alt = image.alt | default: product.title %}
                <button
                  type="button"
                  class="prod-thumb{% if image.id == main_img.id %} is-active{% endif %}"
                  data-buy-thumb
                  data-image-id="{{ image.id }}"
                  data-image-src="{{ image | image_url: width: 1400 }}"
                  data-image-alt="{{ thumb_alt | escape }}"
                  aria-label="Afficher {{ thumb_alt | escape }}"
                  aria-pressed="{% if image.id == main_img.id %}true{% else %}false{% endif %}"
                >
                  {{ image | image_url: width: 160 | image_tag: loading: 'lazy', widths: '80, 120, 160', sizes: '(max-width: 560px) 60px, 72px', alt: thumb_alt }}
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>
        <div class="buy-form-col reveal">
          <h3 class="buy-title">{{ product.title }}</h3>
          {%- render 'product-reassurance' -%}
          {%- comment -%}
            Emplacement 2 — sous le nom du produit, avant le prix (rendu par buy-form).
            Renvoie vers le carrousel de la fiche produit, seul endroit où il existe.
          {%- endcomment -%}
          {%- assign buy_reviews_link = '#avis-google' -%}
          {%- render 'google-rating-badge', variant: 'home_product', href: buy_reviews_link -%}
          {% render 'buy-form', product: product %}
        </div>
      </div>
    {% else %}
      <div class="buy-grid">
        <picture style="display:contents">
          <source type="image/webp" srcset="{{ 'plaque-noire-400.webp' | asset_url }} 400w, {{ 'plaque-noire-800.webp' | asset_url }} 800w" sizes="(max-width: 980px) calc(100vw - 32px), 55vw">
          <img src="{{ 'plaque-noire.jpg' | asset_url }}" width="1254" height="1254" loading="lazy" alt="Plaque Midnight Black" style="border-radius:26px">
        </picture>
        <div class="buy-form-col">
          <p class="eyebrow">Configuration requise</p>
          <p style="margin-top:14px;color:var(--c-grey)">Sélectionnez votre produit « Plaque NFC Google » dans les réglages de cette section pour activer l’achat (variantes Noire / Bleue).</p>
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Choix du modèle + achat",
  "settings": [
    { "type": "text", "id": "title_line1", "label": "Titre — ligne 1", "default": "Deux designs." },
    { "type": "text", "id": "title_line2", "label": "Titre — ligne 2", "default": "Un même impact." },
    { "type": "textarea", "id": "text", "label": "Texte", "default": "Midnight Black pour les comptoirs affirmés, Google Blue pour les enseignes lumineuses. Les deux embarquent la même puce NFC, programmée pour vous." },
    { "type": "product", "id": "product", "label": "Produit" }
  ],
  "presets": [{ "name": "Choix du modèle + achat" }]
}
{% endschema %}
