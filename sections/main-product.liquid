<section class="buy-sec page-pad" style="padding-top:150px">
  <div class="container">
    <div class="buy-grid" data-buy>
      <div>
        {% assign main_img = product.selected_or_first_available_variant.featured_image | default: product.featured_image %}
        {% if main_img %}
          {{ main_img | image_url: width: 1400 | image_tag: loading: 'eager', widths: '360, 540, 750, 1000, 1400', sizes: '(max-width: 980px) calc(100vw - 32px), 55vw', alt: product.title, data-buy-image: '', style: 'border-radius:26px;width:100%' }}
        {% else %}
          <img src="{{ 'plaque-noire.jpg' | asset_url }}" width="1254" height="1254" data-buy-image alt="{{ product.title | escape }}" style="border-radius:26px;width:100%">
        {% endif %}
        {% if product.images.size > 1 %}
          <div class="prod-thumbs prod-thumbs--mobile" aria-label="Images du produit">
            {% for image in product.images %}
              {% assign thumb_alt = image.alt | default: product.title %}
              <button
                type="button"
                class="prod-thumb{% if image.id == main_img.id %} is-active{% endif %}"
                data-buy-thumb
                data-image-id="{{ image.id }}"
                data-image-src="{{ image | image_url: width: 1400 }}"
                data-image-alt="{{ thumb_alt | escape }}"
                aria-label="Afficher {{ thumb_alt | escape }}"
                aria-pressed="{% if image.id == main_img.id %}true{% else %}false{% endif %}"
              >
                {{ image | image_url: width: 160 | image_tag: loading: 'lazy', widths: '80, 120, 160', sizes: '60px', alt: thumb_alt }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
        <div style="margin-top:34px">
          <h1 class="h-lg">{{ product.title }}</h1>
          {%- render 'product-reassurance' -%}
          <div style="margin-top:16px;color:var(--c-grey);max-width:60ch">{{ product.description }}</div>
        </div>
      </div>
      <div class="buy-form-col">
        {% render 'buy-form', product: product %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page produit",
  "settings": []
}
{% endschema %}
