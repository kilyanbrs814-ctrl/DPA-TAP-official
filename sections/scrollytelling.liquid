<section class="scrolly" id="fonctionnement" data-scrolly>
  <div class="scrolly-track">
    <div class="scrolly-sticky">
      <div class="container scrolly-grid">
        <div class="scrolly-steps">
          <p class="eyebrow" style="margin-bottom:26px">{{ section.settings.eyebrow | default: 'Comment ça marche' }}</p>
          {% for block in section.blocks %}
            <h3 class="scrolly-step{% if forloop.first %} is-active{% endif %}" data-step {{ block.shopify_attributes }}>
              <small>Étape {{ forloop.index }}</small>{{ block.settings.title }}
            </h3>
          {% endfor %}
        </div>
        <div class="scrolly-stage" data-phase="1" aria-hidden="true">
          <div class="scrolly-rail"></div>
          {% if section.settings.plaque_image %}
            {{ section.settings.plaque_image | image_url: width: 800 | image_tag: class: 'stage-plaque', loading: 'lazy', alt: '' }}
          {% else %}
            <img class="stage-plaque" src="{{ 'plaque-bleue.jpg' | asset_url }}" width="1254" height="1254" loading="lazy" alt="">
          {% endif %}
          <div class="nfc-waves"><span></span><span></span><span></span></div>
          <div class="stage-phone">
            <div class="phone-screen">
              <div class="nfc-banner" aria-hidden="true">
                <span class="nfc-ico">NFC</span>
                <span class="nfc-txt"><strong>Tag NFC détecté</strong><small>Ouvrir la page d’avis Google</small></span>
              </div>
              <div class="review-ui">
                <p class="rv-name">{{ section.settings.review_name | default: 'Votre établissement' }}</p>
                <p class="rv-sub">Donnez votre avis</p>
                <div class="rv-stars">
                  {% for i in (1..5) %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.9 6.3 6.9.8-5.1 4.7 1.4 6.8L12 17.2 5.9 20.6l1.4-6.8L2.2 9.1l6.9-.8z"/></svg>{% endfor %}
                </div>
                <span class="rv-btn">Publier</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Scrollytelling",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Comment ça marche" },
    { "type": "image_picker", "id": "plaque_image", "label": "Image de la plaque" },
    { "type": "text", "id": "review_name", "label": "Nom affiché sur le téléphone", "default": "Votre établissement" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Étape",
      "limit": 3,
      "settings": [ { "type": "text", "id": "title", "label": "Titre", "default": "Il approche." } ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Scrollytelling",
      "blocks": [
        { "type": "step", "settings": { "title": "Il approche." } },
        { "type": "step", "settings": { "title": "Il touche." } },
        { "type": "step", "settings": { "title": "Il vous note." } }
      ]
    }
  ]
}
{% endschema %}
