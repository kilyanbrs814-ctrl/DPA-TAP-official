<section class="scrolly" id="fonctionnement" data-scrolly>
  <div class="scrolly-track">
    <div class="scrolly-sticky">
      <div class="container scrolly-grid">
        <div class="scrolly-steps">
          <h2 class="eyebrow" style="margin-bottom:26px">{{ section.settings.eyebrow | default: 'Comment ça marche' }}</h2>
          <div class="scrolly-hint" aria-hidden="true">
            <svg class="hint-svg hint-svg--mouse" viewBox="0 0 20 30" fill="none">
              <rect x="1.25" y="1.25" width="17.5" height="27.5" rx="8.75" stroke="currentColor" stroke-width="2"/>
              <line class="hint-wheel" x1="10" y1="7.5" x2="10" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <svg class="hint-svg hint-svg--swipe" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 11v-1a2 2 0 0 0-2-2a2 2 0 0 0-2 2"/>
              <path d="M14 10V9a2 2 0 0 0-2-2a2 2 0 0 0-2 2v1"/>
              <path d="M10 9.5V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v10"/>
              <path d="M18 11a2 2 0 1 1 4 0v3a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/>
            </svg>
            <span class="hint-txt hint-txt--desktop">Faites défiler pour découvrir les étapes</span>
            <span class="hint-txt hint-txt--mobile">Glissez pour découvrir les étapes</span>
            <svg class="hint-svg hint-svg--chevron" viewBox="0 0 14 8" fill="none">
              <path d="M1 1l6 5.5L13 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          {% for block in section.blocks %}
            <div class="scrolly-step{% if forloop.first %} is-active{% endif %}" data-step {{ block.shopify_attributes }}>
              <small>Étape {{ forloop.index }}</small>
              <h3>{{ block.settings.title }}</h3>
            </div>
          {% endfor %}
        </div>
        <div class="scrolly-stage" data-phase="1" aria-hidden="true">
          <div class="scrolly-rail"></div>
          {% if section.settings.plaque_image %}
            {{ section.settings.plaque_image | image_url: width: 800 | image_tag: class: 'stage-plaque', loading: 'lazy', widths: '240, 360, 540, 800', sizes: '(max-width: 900px) 56vw, 320px', alt: '' }}
          {% else %}
            <picture style="display:contents">
              <source type="image/webp" srcset="{{ 'plaque-bleue-400.webp' | asset_url }} 400w, {{ 'plaque-bleue-800.webp' | asset_url }} 800w" sizes="(max-width: 900px) 56vw, 320px">
              <img class="stage-plaque" src="{{ 'plaque-bleue.jpg' | asset_url }}" width="1254" height="1254" loading="lazy" alt="">
            </picture>
          {% endif %}
          <div class="nfc-waves"><span></span><span></span><span></span></div>
          <div class="stage-phone">
            <div class="phone-screen">
              <div class="nfc-banner" aria-hidden="true">
                <span class="nfc-ico">NFC</span>
                <span class="nfc-txt"><strong>Tag NFC détecté</strong><small>Ouvrir la page d’avis Google</small></span>
              </div>
              <div class="review-ui">
                <p class="rv-name">{{ section.settings.review_name | default: 'Votre établissement' }}</p>
                <p class="rv-sub">Donnez votre avis</p>
                <div class="rv-stars">
                  {% for i in (1..5) %}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.9 6.3 6.9.8-5.1 4.7 1.4 6.8L12 17.2 5.9 20.6l1.4-6.8L2.2 9.1l6.9-.8z"/></svg>{% endfor %}
                </div>
                <span class="rv-btn">Publier</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Scrollytelling",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Comment ça marche" },
    { "type": "image_picker", "id": "plaque_image", "label": "Image de la plaque" },
    { "type": "text", "id": "review_name", "label": "Nom affiché sur le téléphone", "default": "Votre établissement" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Étape",
      "limit": 3,
      "settings": [ { "type": "text", "id": "title", "label": "Titre", "default": "Il approche." } ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Scrollytelling",
      "blocks": [
        { "type": "step", "settings": { "title": "Il approche." } },
        { "type": "step", "settings": { "title": "Il touche." } },
        { "type": "step", "settings": { "title": "Il vous note." } }
      ]
    }
  ]
}
{% endschema %}
