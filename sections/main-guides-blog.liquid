<section class="guides-index">
  <div class="container">
    {% render 'seo-breadcrumbs', current_title: blog.title %}
    <header class="guides-index__header">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ blog.title }}</h1>
      <div class="guides-index__intro">{{ section.settings.intro }}</div>
    </header>

    {% paginate blog.articles by 12 %}
      <div class="guides-index__grid">
        {% for article in blog.articles %}
          <article class="guides-index__card">
            {% if article.image %}
              <a class="guides-index__image" href="{{ article.url }}" tabindex="-1" aria-hidden="true">
                {{ article.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 760, 900', sizes: '(max-width: 759px) calc(100vw - 32px), 33vw', alt: '' }}
              </a>
            {% endif %}
            <div class="guides-index__body">
              <p class="eyebrow">{{ 'seo.guide' | t }}</p>
              <h2><a href="{{ article.url }}">{{ article.title }}</a></h2>
              {% if article.excerpt != blank %}<p>{{ article.excerpt | strip_html | truncate: 170 }}</p>{% endif %}
              <a class="guides-index__link" href="{{ article.url }}">{{ 'seo.read_guide' | t }}</a>
            </div>
          </article>
        {% else %}
          <p>{{ section.settings.empty_text }}</p>
        {% endfor %}
      </div>
      {% if paginate.pages > 1 %}<div class="guides-index__pagination">{{ paginate | default_pagination }}</div>{% endif %}
    {% endpaginate %}
  </div>
</section>

{% stylesheet %}
  .guides-index {
    min-height: 100vh;
    padding: 128px 0 96px;
    background: var(--c-paper);
    color: var(--c-ink);
  }

  .guides-index__header {
    max-width: 820px;
  }

  .guides-index__header h1 {
    margin-top: 14px;
    font-size: clamp(2.6rem, 9vw, 6rem);
  }

  .guides-index__intro {
    max-width: 65ch;
    margin-top: 24px;
    color: #5f5f63;
    font-size: 1.1rem;
  }

  .guides-index__grid {
    display: grid;
    gap: 20px;
    margin-top: 56px;
  }

  .guides-index__card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 22px;
    background: #fff;
  }

  .guides-index__image {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: #e8e5de;
  }

  .guides-index__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .guides-index__body {
    padding: 24px;
  }

  .guides-index__body h2 {
    margin-top: 12px;
    font-size: 1.5rem;
    line-height: 1.2;
  }

  .guides-index__body h2 a {
    text-decoration: none;
  }

  .guides-index__body > p:not(.eyebrow) {
    margin-top: 16px;
    color: #5f5f63;
  }

  .guides-index__link {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    margin-top: 18px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    text-underline-offset: 4px;
  }

  .guides-index__pagination {
    margin-top: 40px;
  }

  .guides-index__pagination a,
  .guides-index__pagination .current {
    min-width: 44px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 760px) {
    .guides-index {
      padding-top: 150px;
      padding-bottom: 128px;
    }

    .guides-index__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .guides-index {
      padding-top: 112px;
      padding-bottom: 72px;
    }

    .guides-index .container {
      width: min(100% - 32px, 1240px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Index des Guides",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Surtitre", "default": "Conseils pratiques" },
    { "type": "richtext", "id": "intro", "label": "Introduction", "default": "<p>Comprendre le NFC, choisir la bonne méthode et préparer le lien d’avis Google de votre établissement.</p>" },
    { "type": "text", "id": "empty_text", "label": "Texte si aucun article", "default": "Les premiers guides sont en préparation." }
  ]
}
{% endschema %}
