{%- comment -%}
  DPA TAP — Bandeau de réassurance défilant (marquee CSS).
  Placé au-dessus du header dans layout/theme.liquid, visible sur toutes les pages.
  Aucun JavaScript, aucune bibliothèque externe.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign icon_size = s.icon_size | default: 16
  assign fs_desktop = s.text_size_desktop | default: 12
  assign fs_mobile = s.text_size_mobile | default: 11
  assign speed = s.speed | default: 45
-%}

{%- if s.enabled -%}

  {%- capture mq_group -%}
    {%- for i in (1..5) -%}
      {%- liquid
        assign k_on = 'item_' | append: i | append: '_enabled'
        assign k_text = 'item_' | append: i | append: '_text'
        assign k_icon = 'item_' | append: i | append: '_icon'
        assign item_on = s[k_on]
        assign item_text = s[k_text] | strip
      -%}
      {%- if item_on and item_text != blank -%}
        <span class="dpa-mq__item">
          {%- if s.show_icons -%}{%- render 'dpa-marquee-icon', name: s[k_icon] -%}{%- endif -%}
          <span class="dpa-mq__label">{{ item_text | escape }}</span>
        </span>
        {%- if s.separator != 'none' -%}
          <span class="dpa-mq__sep dpa-mq__sep--{{ s.separator }}" aria-hidden="true">
            {%- if s.separator == 'dot' -%}&bull;{%- elsif s.separator == 'star' -%}&#10022;{%- endif -%}
          </span>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}

  {%- if mq_group != blank -%}
    <style>
      :root{
        --dpa-mq-fs: {{ fs_desktop }}px;
        --dpa-mq-icon: {{ icon_size }}px;
        --dpa-mq-pad: 9px;
        --dpa-mq-gap: 22px;
        --dpa-mq-h: calc(max(var(--dpa-mq-fs) * 1.35, var(--dpa-mq-icon)) + var(--dpa-mq-pad) * 2);
      }
      html{ scroll-padding-top: var(--dpa-mq-h); }
      body{ padding-top: var(--dpa-mq-h); }
      .hdr{ top: calc(var(--dpa-mq-h) + 14px); }
      /* Élément collant du scrollytelling : décalé pour ne pas passer sous la bannière. */
      .scrolly-sticky{ top: var(--dpa-mq-h); height: calc(100svh - var(--dpa-mq-h)); }

      .dpa-mq{
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 101;
        height: var(--dpa-mq-h);
        display: flex;
        align-items: center;
        overflow: hidden;
        background: {{ s.color_background }};
        color: {{ s.color_text }};
        border-bottom: 1px solid rgba(255,255,255,.07);
        contain: content;
      }
      .dpa-mq__track{
        display: flex;
        width: max-content;
        will-change: transform;
        animation: dpa-mq-scroll {{ speed }}s linear infinite;
      }
      .dpa-mq__group{
        display: flex;
        align-items: center;
        gap: var(--dpa-mq-gap);
        padding-right: var(--dpa-mq-gap);
        flex: 0 0 auto;
      }
      .dpa-mq__item{
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        font-family: "Space Grotesk", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
        font-weight: 600;
        font-size: var(--dpa-mq-fs);
        line-height: 1.2;
        letter-spacing: .09em;
        text-transform: uppercase;
      }
      .dpa-mq__label{ display: inline-block; }
      .dpa-mq__icon{
        width: var(--dpa-mq-icon);
        height: var(--dpa-mq-icon);
        flex: 0 0 auto;
        display: block;
        color: currentColor;
      }
      .dpa-mq__sep{
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        opacity: .42;
        font-size: calc(var(--dpa-mq-fs) * .9);
        line-height: 1;
        user-select: none;
      }
      .dpa-mq__sep--bar{
        width: 1px;
        height: calc(var(--dpa-mq-fs) * 1.25);
        background: currentColor;
      }

      @keyframes dpa-mq-scroll{
        from{ transform: translate3d(0,0,0); }
        to{ transform: translate3d(-50%,0,0); }
      }

      @media (hover: hover) and (pointer: fine){
        .dpa-mq:hover .dpa-mq__track{ animation-play-state: paused; }
      }

      @media (max-width: 900px){
        :root{
          --dpa-mq-fs: {{ fs_mobile }}px;
          --dpa-mq-icon: {{ icon_size | minus: 2 }}px;
          --dpa-mq-pad: 8px;
          --dpa-mq-gap: 16px;
        }
        .hdr{ top: calc(var(--dpa-mq-h) + max(8px, env(safe-area-inset-top))); }
        .dpa-mq__item{ gap: 7px; letter-spacing: .07em; }
      }

      @media (prefers-reduced-motion: reduce){
        .dpa-mq{ overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
        .dpa-mq::-webkit-scrollbar{ display: none; }
        .dpa-mq__track{ animation: none; will-change: auto; }
        .dpa-mq__track > [aria-hidden="true"]{ display: none; }
        .dpa-mq__group{ padding-left: var(--dpa-mq-gap); }
      }
    </style>

    <div class="dpa-mq" role="region" aria-label="{{ s.aria_label | default: 'Avantages DPA TAP' | escape }}">
      <div class="dpa-mq__track">
        <div class="dpa-mq__group">{{ mq_group }}</div>
        <div class="dpa-mq__group" aria-hidden="true">{{ mq_group }}</div>
      </div>
    </div>
  {%- endif -%}

{%- endif -%}

