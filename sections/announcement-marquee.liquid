{%- comment -%}
  DPA TAP — Bandeau de réassurance défilant (marquee CSS).

  Deux variantes servies par la même section, aucun doublon de code :
  - "topbar"  : barre fine fixée en haut, rendue par layout/theme.liquid sur
                toutes les pages SAUF l'accueil.
  - "feature" : grand bandeau dans le flux, inséré via templates/index.json
                entre le hero et le scrollytelling « Comment ça marche ».

  Le CSS est scopé sur l'id unique de la section, donc les deux variantes
  peuvent coexister sans collision. Aucun JavaScript, aucune librairie externe.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign variant = s.variant | default: 'topbar'
  assign uid = 'dpa-mq-' | append: section.id
  assign icon_d = s.icon_size | default: 16
  assign icon_m = s.icon_size_mobile | default: 14
  assign fs_d = s.text_size_desktop | default: 12
  assign fs_m = s.text_size_mobile | default: 11
  assign pad_d = s.pad_desktop | default: 9
  assign pad_m = s.pad_mobile | default: 8
  assign gap_d = s.gap_desktop | default: 22
  assign gap_m = s.gap_mobile | default: 16
  assign speed = s.speed | default: 45
  assign sep_op = s.separator_opacity | default: 42
-%}

{%- if s.enabled -%}

  {%- capture mq_group -%}
    {%- for i in (1..5) -%}
      {%- liquid
        assign k_on = 'item_' | append: i | append: '_enabled'
        assign k_text = 'item_' | append: i | append: '_text'
        assign k_icon = 'item_' | append: i | append: '_icon'
        assign item_on = s[k_on]
        assign item_text = s[k_text] | strip
      -%}
      {%- if item_on and item_text != blank -%}
        <span class="dpa-mq__item">
          {%- if s.show_icons -%}{%- render 'dpa-marquee-icon', name: s[k_icon] -%}{%- endif -%}
          <span class="dpa-mq__label">{{ item_text | escape }}</span>
        </span>
        {%- if s.separator != 'none' -%}
          <span class="dpa-mq__sep dpa-mq__sep--{{ s.separator }}" aria-hidden="true">
            {%- if s.separator == 'dot' -%}&bull;{%- elsif s.separator == 'star' -%}&#10022;{%- endif -%}
          </span>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}

  {%- if mq_group != blank -%}
    <style>
      {%- if variant == 'topbar' -%}
      /* Variante barre fine : position fixe, donc le reste de la page doit être
         décalé de la hauteur exacte de la barre. Une seule instance par page. */
      :root{
        --dpa-mq-fs: {{ fs_d }}px;
        --dpa-mq-icon: {{ icon_d }}px;
        --dpa-mq-pad: {{ pad_d }}px;
        --dpa-mq-gap: {{ gap_d }}px;
        --dpa-mq-h: calc(max(var(--dpa-mq-fs) * 1.35, var(--dpa-mq-icon)) + var(--dpa-mq-pad) * 2);
      }
      html{ scroll-padding-top: var(--dpa-mq-h); }
      body{ padding-top: var(--dpa-mq-h); }
      .hdr{ top: calc(var(--dpa-mq-h) + 14px); }
      /* Élément collant du scrollytelling : décalé pour ne pas passer sous la barre. */
      .scrolly-sticky{ top: var(--dpa-mq-h); height: calc(100svh - var(--dpa-mq-h)); }

      #{{ uid }}{
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 101;
        height: var(--dpa-mq-h);
        border-bottom: 1px solid rgba(255,255,255,.07);
      }
      @media (max-width: 900px){
        :root{
          --dpa-mq-fs: {{ fs_m }}px;
          --dpa-mq-icon: {{ icon_m }}px;
          --dpa-mq-pad: {{ pad_m }}px;
          --dpa-mq-gap: {{ gap_m }}px;
        }
        .hdr{ top: calc(var(--dpa-mq-h) + max(8px, env(safe-area-inset-top))); }
      }
      {%- else -%}
      /* Variante grand bandeau : dans le flux, aucune compensation de layout.
         Les variables restent locales à la section. */
      #{{ uid }}{
        --dpa-mq-fs: {{ fs_d }}px;
        --dpa-mq-icon: {{ icon_d }}px;
        --dpa-mq-pad: {{ pad_d }}px;
        --dpa-mq-gap: {{ gap_d }}px;
        --dpa-mq-h: calc(max(var(--dpa-mq-fs) * 1.35, var(--dpa-mq-icon)) + var(--dpa-mq-pad) * 2);
        position: relative;
        width: 100%;
        height: var(--dpa-mq-h);
        border-top: 1px solid color-mix(in srgb, {{ s.color_text }} 16%, transparent);
        border-bottom: 1px solid color-mix(in srgb, {{ s.color_text }} 16%, transparent);
      }
      @media (max-width: 900px){
        #{{ uid }}{
          --dpa-mq-fs: {{ fs_m }}px;
          --dpa-mq-icon: {{ icon_m }}px;
          --dpa-mq-pad: {{ pad_m }}px;
          --dpa-mq-gap: {{ gap_m }}px;
        }
      }
      {%- if s.tighten_neighbours -%}
      /* Resserre l'enchaînement hero → bandeau → « Comment ça marche ».
         Ces règles ne sont émises que si la variante grand bandeau est posée
         entre les deux sections, et disparaissent avec elle. */
      .hero{ padding-bottom: {{ s.space_above | default: 28 }}px; }
      .scrolly-sticky{ align-content: start; padding-top: {{ s.space_below | default: 56 }}px; }
      @media (max-width: 900px){
        .hero{ padding-bottom: {{ s.space_above_mobile | default: 20 }}px; }
        .scrolly-sticky{ padding-top: {{ s.space_below_mobile | default: 32 }}px; }
      }
      {%- endif -%}
      {%- endif -%}

      /* ---- Règles communes aux deux variantes ---- */
      #{{ uid }}{
        display: flex;
        align-items: center;
        overflow: hidden;
        background: {{ s.color_background }};
        color: {{ s.color_text }};
        contain: content;
      }
      #{{ uid }} .dpa-mq__track{
        display: flex;
        width: max-content;
        will-change: transform;
        animation: dpa-mq-scroll {{ speed }}s linear infinite;
      }
      #{{ uid }} .dpa-mq__group{
        display: flex;
        align-items: center;
        gap: var(--dpa-mq-gap);
        padding-right: var(--dpa-mq-gap);
        flex: 0 0 auto;
      }
      #{{ uid }} .dpa-mq__item{
        display: inline-flex;
        align-items: center;
        gap: calc(var(--dpa-mq-fs) * .5);
        white-space: nowrap;
        font-family: "Space Grotesk", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
        font-weight: 600;
        font-size: var(--dpa-mq-fs);
        line-height: 1.2;
        letter-spacing: .09em;
        text-transform: uppercase;
      }
      #{{ uid }} .dpa-mq__label{ display: inline-block; }
      #{{ uid }} .dpa-mq__icon{
        width: var(--dpa-mq-icon);
        height: var(--dpa-mq-icon);
        flex: 0 0 auto;
        display: block;
        color: currentColor;
      }
      #{{ uid }} .dpa-mq__sep{
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        opacity: {{ sep_op | divided_by: 100.0 }};
        font-size: calc(var(--dpa-mq-fs) * .9);
        line-height: 1;
        user-select: none;
      }
      #{{ uid }} .dpa-mq__sep--bar{
        width: 1px;
        height: calc(var(--dpa-mq-fs) * 1.25);
        background: currentColor;
      }
      @media (max-width: 900px){
        #{{ uid }} .dpa-mq__item{ letter-spacing: .07em; }
      }

      /* La piste contient 5 groupes identiques : un cycle translate exactement
         un groupe (-20%), et les 4 groupes restants garantissent que la piste
         couvre toujours la largeur du viewport, même en très grand écran.
         Aucun vide, donc aucun saut au redémarrage. */
      @keyframes dpa-mq-scroll{
        from{ transform: translate3d(0,0,0); }
        to{ transform: translate3d(-20%,0,0); }
      }

      @media (hover: hover) and (pointer: fine){
        #{{ uid }}:hover .dpa-mq__track{ animation-play-state: paused; }
      }

      @media (prefers-reduced-motion: reduce){
        #{{ uid }}{ overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
        #{{ uid }}::-webkit-scrollbar{ display: none; }
        #{{ uid }} .dpa-mq__track{ animation: none; will-change: auto; }
        #{{ uid }} .dpa-mq__track > [aria-hidden="true"]{ display: none; }
        #{{ uid }} .dpa-mq__group{ padding-left: var(--dpa-mq-gap); }
      }
    </style>

    <div id="{{ uid }}" class="dpa-mq dpa-mq--{{ variant }}" role="region" aria-label="{{ s.aria_label | default: 'Avantages DPA TAP' | escape }}">
      <div class="dpa-mq__track">
        <div class="dpa-mq__group">{{ mq_group }}</div>
        <div class="dpa-mq__group" aria-hidden="true">{{ mq_group }}</div>
        <div class="dpa-mq__group" aria-hidden="true">{{ mq_group }}</div>
        <div class="dpa-mq__group" aria-hidden="true">{{ mq_group }}</div>
        <div class="dpa-mq__group" aria-hidden="true">{{ mq_group }}</div>
      </div>
    </div>
  {%- endif -%}

{%- endif -%}

