<section class="page-pad">
  <div class="container">
    <h1 class="h-lg" style="margin-bottom:44px">Votre panier</h1>
    {% if cart.item_count == 0 %}
      <div class="empty-state">
        <h2 class="h-lg">Il est encore vide.</h2>
        <p>Votre future plaque n’attend que vous.</p>
        <a class="btn btn--ink" href="{{ routes.root_url }}#modeles">Choisir ma plaque</a>
      </div>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post">
        <table class="cart-table">
          <thead>
            <tr><th scope="col">Produit</th><th scope="col">Quantité</th><th scope="col">Total</th><th scope="col"><span class="visually-hidden">Retirer</span></th></tr>
          </thead>
          <tbody>
            {% for item in cart.items %}
              <tr>
                <td data-label="Produit">
                  <div class="cart-item">
                    {% if item.image %}{{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.title }}{% endif %}
                    <div>
                      <p class="t">{{ item.product.title }}</p>
                      {% if item.variant.title != 'Default Title' %}<p class="p">{{ item.variant.title }}</p>{% endif %}
                      {% for property in item.properties %}
                        {% if property.last != blank %}
                          {% if property.first contains 'Lien' %}
                            <p class="p">{{ property.first }} : <a class="cart-link" href="{{ property.last }}" target="_blank" rel="noopener nofollow">{{ property.last }}</a></p>
                          {% else %}
                            <p class="p">{{ property.first }} : {{ property.last }}</p>
                          {% endif %}
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                </td>
                <td data-label="Quantité">
                  <label class="visually-hidden" for="updates_{{ item.key }}">Quantité</label>
                  <div class="qty" style="border-color:color-mix(in srgb,var(--c-ink) 20%,transparent)">
                    <input id="updates_{{ item.key }}" style="color:var(--c-ink)" type="number" name="updates[]" value="{{ item.quantity }}" min="0" inputmode="numeric">
                  </div>
                </td>
                <td data-label="Total">
                  {% if item.original_line_price > item.final_line_price %}
                    <s class="cart-was">{{ item.original_line_price | money }}</s>
                    <span class="cart-now">{{ item.final_line_price | money }}</span>
                  {% else %}
                    {{ item.final_line_price | money }}
                  {% endif %}
                </td>
                <td data-label="Action"><a href="{{ item.url_to_remove }}" aria-label="Retirer {{ item.product.title | escape }}">Retirer</a></td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
        <div class="cart-foot">
          <div class="cart-note">
            <label for="cart-note" class="eyebrow" style="display:block;margin-bottom:10px">Note pour la commande</label>
            <textarea id="cart-note" name="note">{{ cart.note }}</textarea>
            <p style="margin-top:16px"><button type="submit" class="btn btn--ghost" style="color:var(--c-ink);border-color:color-mix(in srgb,var(--c-ink) 30%,transparent)">Mettre à jour</button></p>
          </div>
          <div class="cart-summary">
            {%- comment -%}
              Réduction pack : montants issus de Shopify (cart.total_discount,
              appliqué par la remise auto « Pack 2 plaques : -14,50 € » dès 2
              plaques). Rien n'est codé en dur ; si aucune remise n'est active,
              seul le sous-total s'affiche. T095.
            {%- endcomment -%}
            {% if cart.total_discount > 0 %}
              <div class="row row--muted"><span>Sous-total</span><span>{{ cart.original_total_price | money }}</span></div>
              <div class="row row--save"><span>Réduction pack</span><span>−{{ cart.total_discount | money }}</span></div>
              <div class="row"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
            {% else %}
              <div class="row"><span>Sous-total</span><span>{{ cart.total_price | money }}</span></div>
            {% endif %}
            <p class="small">Livraison gratuite en France — à domicile ou en point relais · expédiée sous 24 h. Taxes calculées au paiement.</p>
            <p class="small cart-guarantee">🛡 <a href="{{ routes.root_url }}pages/garantie-a-vie" style="color:inherit">Garantie à vie</a> — panne ou casse remplacées gratuitement.</p>
            <p class="cart-verify">Avant de payer, vérifiez le nom de votre établissement, votre lien Google, la couleur et la quantité de chaque plaque.</p>
            {%- comment -%}
              Emplacement 5 — réassurance agrégée entre le sous-total et le
              bouton de paiement. Badge seul : aucune liste d'avis n'est
              rechargée ici, aucun widget tiers n'est injecté.
            {%- endcomment -%}
            {%- render 'google-rating-badge', variant: 'cart' -%}
            <button type="submit" name="checkout" class="btn btn--blue">Paiement sécurisé</button>
          </div>
        </div>
      </form>
    {% endif %}
  </div>
</section>
<style>
  .visually-hidden{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0)}
  .cart-link{color:var(--g-blue);text-decoration:underline;word-break:break-all}
  .cart-was{opacity:.55;margin-right:8px}
  .cart-now{font-weight:600}
  .cart-summary .row--muted,.cart-summary .row--save{font-size:1rem;font-weight:500}
  .cart-summary .row--save{color:var(--g-green)}
  .cart-summary .row--muted span:last-child{text-decoration:line-through;opacity:.6}
  .cart-summary .row+.row{margin-top:8px}
  .cart-verify{font-size:.82rem;line-height:1.45;color:var(--c-grey);background:color-mix(in srgb,var(--c-ink) 5%,transparent);border-radius:12px;padding:12px 14px;margin-top:16px}
</style>

{% schema %}
{
  "name": "Panier",
  "settings": []
}
{% endschema %}
