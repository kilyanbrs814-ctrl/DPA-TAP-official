{%- if section.settings.image == blank and section.settings.image_mobile == blank -%}
  <link rel="preload" as="image" href="{{ 'hero-banner-mobile.jpg' | asset_url }}" media="(max-width: 900px)">
  <link rel="preload" as="image" type="image/webp" imagesrcset="{{ 'hero-banner-1100.webp' | asset_url }} 1100w, {{ 'hero-banner-1400.webp' | asset_url }} 1400w, {{ 'hero-banner-1706.webp' | asset_url }} 1706w" imagesizes="100vw" media="(min-width: 901px)">
{%- endif -%}
<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    {%- if section.settings.image_mobile != blank or section.settings.image != blank -%}
      <picture>
        {%- if section.settings.image_mobile != blank -%}
          <source media="(max-width: 900px)" srcset="{{ section.settings.image_mobile | image_url: width: 480 }} 480w, {{ section.settings.image_mobile | image_url: width: 750 }} 750w, {{ section.settings.image_mobile | image_url: width: 1100 }} 1100w" sizes="100vw">
        {%- else -%}
          {%- comment -%}
            Fond Hero mobile dédié (portrait 9:16), sous 768 px uniquement.
            L'image desktop (section.settings.image) reste servie à partir de
            768 px : elle n'est jamais remplacée par un recadrage du mobile.
            La balise <picture> ne télécharge qu'une seule des deux versions.
          {%- endcomment -%}
          <source media="(max-width: 767px)" type="image/webp" srcset="{{ 'dpa-hero-mobile-1080x1920.webp' | asset_url }}" width="1080" height="1920">
        {%- endif -%}
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 2200 | image_tag: widths: '480, 750, 1100, 1600, 2200', sizes: '100vw', alt: '', loading: 'eager', fetchpriority: 'high' }}
        {%- else -%}
          <source type="image/webp" srcset="{{ 'hero-banner-1100.webp' | asset_url }} 1100w, {{ 'hero-banner-1400.webp' | asset_url }} 1400w, {{ 'hero-banner-1706.webp' | asset_url }} 1706w" sizes="100vw">
          <img src="{{ 'hero-banner.png' | asset_url }}" width="1706" height="922" alt="" fetchpriority="high">
        {%- endif -%}
      </picture>
    {%- else -%}
      <picture>
        <source media="(max-width: 900px)" srcset="{{ 'hero-banner-mobile.jpg' | asset_url }}">
        <source type="image/webp" srcset="{{ 'hero-banner-1100.webp' | asset_url }} 1100w, {{ 'hero-banner-1400.webp' | asset_url }} 1400w, {{ 'hero-banner-1706.webp' | asset_url }} 1706w" sizes="100vw">
        <img src="{{ 'hero-banner.png' | asset_url }}" width="1706" height="922" alt="" fetchpriority="high">
      </picture>
    {%- endif -%}
  </div>
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="hero-eyebrow">PLAQUE NFC AVIS GOOGLE</p>
      <h1 class="h-display reveal"><span class="hero-title-line">{{ section.settings.title_line1 | default: 'Un avis Google' }}</span> <em class="hero-title-line">{{ section.settings.title_line2 | default: 'en un geste.' }}</em></h1>
      <p class="hero-sub reveal">{{ section.settings.subtitle | default: 'La plaque NFC pour avis Google qui transforme chaque client satisfait en une preuve qui fait grandir votre commerce.' }}</p>
      <div class="hero-cta reveal">
        <a class="btn btn--blue" href="{{ section.settings.cta1_link | default: '/products/plaque-nfc-avis-google' }}">{{ section.settings.cta1_label | default: 'Choisir ma plaque' }}</a>
        <a class="btn btn--ghost" href="{{ section.settings.cta2_link | default: '#fonctionnement' }}">{{ section.settings.cta2_label | default: 'Voir comment ça marche' }}</a>
      </div>
      {%- comment -%}
        Emplacement 1 — badge de confiance sous le CTA.
        Le carrousel complet ne vit que sur la fiche produit : le lien pointe
        donc vers l'ancre de cette page, pas vers une ancre locale.
      {%- endcomment -%}
      <div class="reveal">
        {%- assign hero_reviews_link = section.settings.reviews_link | default: '/products/plaque-nfc-avis-google' | append: '#avis-google' -%}
        {%- render 'google-rating-badge', variant: 'hero', href: hero_reviews_link -%}
      </div>
    </div>
  </div>
  <p class="hero-scrollhint">{{ section.settings.scroll_hint | default: 'Faites défiler' }}</p>
</section>

{% schema %}
{
  "name": "Hero immersif",
  "settings": [
    { "type": "text", "id": "title_line1", "label": "Titre — ligne 1", "default": "Un avis Google" },
    { "type": "text", "id": "title_line2", "label": "Titre — ligne 2", "default": "en un geste." },
    { "type": "textarea", "id": "subtitle", "label": "Sous-titre", "default": "La plaque NFC pour avis Google qui transforme chaque client satisfait en une preuve qui fait grandir votre commerce." },
    { "type": "text", "id": "cta1_label", "label": "Bouton 1 — libellé", "default": "Choisir ma plaque" },
    { "type": "url", "id": "cta1_link", "label": "Bouton 1 — lien" },
    { "type": "text", "id": "cta2_label", "label": "Bouton 2 — libellé", "default": "Voir comment ça marche" },
    { "type": "url", "id": "cta2_link", "label": "Bouton 2 — lien" },
    { "type": "image_picker", "id": "image", "label": "Image de fond (ordinateur)" },
    { "type": "image_picker", "id": "image_mobile", "label": "Image de fond (mobile)" },
    { "type": "text", "id": "scroll_hint", "label": "Indication de défilement", "default": "Faites défiler" },
    { "type": "url", "id": "reviews_link", "label": "Lien du badge d’avis", "info": "Page portant le carrousel d’avis. L’ancre #avis-google est ajoutée automatiquement." }
  ],
  "presets": [{ "name": "Hero immersif" }]
}
{% endschema %}
