<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    {%- if section.settings.image_mobile != blank or section.settings.image != blank -%}
      <picture>
        {%- if section.settings.image_mobile != blank -%}
          <source media="(max-width: 900px)" srcset="{{ section.settings.image_mobile | image_url: width: 1100 }}">
        {%- endif -%}
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 2200 | image_tag: widths: '1100, 1600, 2200', sizes: '100vw', alt: '', loading: 'eager', fetchpriority: 'high' }}
        {%- else -%}
          <img src="{{ 'hero-banner.png' | asset_url }}" width="1706" height="922" alt="" fetchpriority="high">
        {%- endif -%}
      </picture>
    {%- else -%}
      <img src="{{ 'hero-banner.png' | asset_url }}" width="1706" height="922" alt="" fetchpriority="high">
    {%- endif -%}
  </div>
  <div class="container hero-grid">
    <div>
      <h1 class="h-display reveal" style="margin-top:22px">{{ section.settings.title_line1 | default: 'Un geste.' }}<br><em>{{ section.settings.title_line2 | default: 'Un avis.' }}</em></h1>
      <p class="hero-sub reveal">{{ section.settings.subtitle | default: 'Transformez chaque client satisfait en une preuve qui fait grandir votre commerce.' }}</p>
      <div class="hero-cta reveal">
        <a class="btn btn--blue" href="{{ section.settings.cta1_link | default: '#modeles' }}">{{ section.settings.cta1_label | default: 'Choisir ma plaque' }}</a>
        <a class="btn btn--ghost" href="{{ section.settings.cta2_link | default: '#fonctionnement' }}">{{ section.settings.cta2_label | default: 'Voir comment ça marche' }}</a>
      </div>
    </div>
  </div>
  <p class="hero-scrollhint">{{ section.settings.scroll_hint | default: 'Faites défiler' }}</p>
</section>

{% schema %}
{
  "name": "Hero immersif",
  "settings": [
    { "type": "text", "id": "title_line1", "label": "Titre — ligne 1", "default": "Un geste." },
    { "type": "text", "id": "title_line2", "label": "Titre — ligne 2", "default": "Un avis." },
    { "type": "textarea", "id": "subtitle", "label": "Sous-titre", "default": "Transformez chaque client satisfait en une preuve qui fait grandir votre commerce." },
    { "type": "text", "id": "cta1_label", "label": "Bouton 1 — libellé", "default": "Choisir ma plaque" },
    { "type": "url", "id": "cta1_link", "label": "Bouton 1 — lien" },
    { "type": "text", "id": "cta2_label", "label": "Bouton 2 — libellé", "default": "Voir comment ça marche" },
    { "type": "url", "id": "cta2_link", "label": "Bouton 2 — lien" },
    { "type": "image_picker", "id": "image", "label": "Image de fond (ordinateur)" },
    { "type": "image_picker", "id": "image_mobile", "label": "Image de fond (mobile)" },
    { "type": "text", "id": "scroll_hint", "label": "Indication de défilement", "default": "Faites défiler" }
  ],
  "presets": [{ "name": "Hero immersif" }]
}
{% endschema %}
