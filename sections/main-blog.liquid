<section class="page-pad"><div class="container"><h1 class="h-lg">{{ blog.title }}</h1>
<div style="display:grid;gap:24px;margin-top:44px">
  {% for article in blog.articles %}<a href="{{ article.url }}" style="text-decoration:none"><strong>{{ article.title }}</strong><br><span style="color:var(--c-grey)">{{ article.published_at | date: '%d/%m/%Y' }}</span></a>{% endfor %}
</div></div></section>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
