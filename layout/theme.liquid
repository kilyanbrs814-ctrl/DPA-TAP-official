<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {%- liquid
    assign seo_title = page_title
    assign seo_description = page_description
  -%}
  <title>{{ seo_title }}{% unless seo_title contains shop.name %} — {{ shop.name }}{% endunless %}</title>
  {% if seo_description %}<meta name="description" content="{{ seo_description | escape }}">{% endif %}
  <link rel="canonical" href="{{ canonical_url }}">
  {% if settings.favicon %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 96, height: 96, crop: 'center' }}">
    <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180, crop: 'center' }}">
  {% endif %}
  <meta property="og:title" content="{{ seo_title | escape }}">
  {% if seo_description %}<meta property="og:description" content="{{ seo_description | escape }}">{% endif %}
  {% if page_image %}<meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">{% endif %}
  {%- comment -%}
    Identité de l'entreprise. Uniquement des informations déjà publiées dans les
    mentions légales du site. Pas de sameAs (aucun profil officiel existant),
    pas de LocalBusiness (pas d'accueil de public), pas d'AggregateRating.
  {%- endcomment -%}
  {%- if template.name == 'index' -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "{{ shop.url }}/#organization",
      "name": "DPA TAP",
      "legalName": "Kilyan Bouras",
      "url": "{{ shop.url }}",
      "logo": "https:{{ 'logo-dpa-tap.png' | asset_url | split: '?' | first }}",
      "email": "kilyan.brs814@gmail.com",
      "telephone": "+33753801415",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "127 rue Élie Augustin",
        "postalCode": "81400",
        "addressLocality": "Blaye-les-Mines",
        "addressCountry": "FR"
      },
      "identifier": {
        "@type": "PropertyValue",
        "propertyID": "SIRET",
        "value": "10406462100014"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "email": "kilyan.brs814@gmail.com",
        "telephone": "+33753801415",
        "areaServed": "FR",
        "availableLanguage": "fr"
      }
    }
    </script>
  {%- endif -%}
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all';this.onload=null">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>
  <style>
    :root{
      --c-ink: {{ settings.color_ink | default: '#101012' }};
      --c-bg: {{ settings.color_bg | default: '#0b0b0c' }};
      --c-paper: {{ settings.color_paper | default: '#f4f2ed' }};
      --c-grey: {{ settings.color_grey | default: '#8a8a8e' }};
      --g-blue: {{ settings.color_blue | default: '#4285F4' }};
      --g-red: #EA4335;
      --g-yellow: #FBBC05;
      --g-green: #34A853;
    }
  </style>
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <script>
    window.DPA = {
      moneyFormat: {{ shop.money_format | json }},
      cartCount: {{ cart.item_count }},
      routes: { cartAdd: "{{ routes.cart_add_url }}.js", cart: "{{ routes.cart_url }}", cartJs: "{{ routes.cart_url }}.js" }
    };
  </script>
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</head>
<body class="template-{{ template | split: '.' | first }}">
  <a class="skip-link" href="#main">Aller au contenu</a>
  {% section 'announcement-marquee' %}
  {% section 'header' %}
  <main id="main">{{ content_for_layout }}</main>
  {% section 'footer' %}
</body>
</html>

